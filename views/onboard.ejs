<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body class="p-0 m-0">
<div class="login-wrapper">
  <div class="login-card fade-in" style="max-width:460px;">
    <div class="login-logo">
      <i class="bi bi-person-fill-check" style="font-size:1.5rem;"></i>
    </div>
    <div class="login-title">Complete Your Profile</div>
    <div class="login-subtitle">Tell us about yourself before continuing.</div>

    <% if (error_msg && error_msg.length > 0) { %>
    <div class="alert alert-danger border-0 rounded-3 py-2 px-3 small">
      <i class="bi bi-exclamation-triangle-fill me-1"></i> <%= error_msg %>
    </div>
    <% } %>

    <form action="/auth/onboard" method="POST">
      <div class="mb-3">
        <label class="form-label fw-semibold">College <span class="text-danger">*</span></label>
        <select name="collegeName" class="form-select" required>
          <option value="" disabled selected>Select your college...</option>
          <% colleges.forEach(c => { %>
          <option value="<%= c.name %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="mb-4">
        <label class="form-label fw-semibold">Mobile Number</label>
        <input type="tel" name="mobile" class="form-control"
               placeholder="10-digit mobile number" maxlength="10" pattern="[6-9][0-9]{9}">
      </div>
      <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
        <i class="bi bi-check-circle me-1"></i>Complete Setup
      </button>
    </form>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
