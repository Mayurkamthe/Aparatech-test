<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — OMVSAB</title>
  <%- include('partials/pwa-head') %>
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
  <style>
    .admin-login-wrapper {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0a1628 0%, #0d47a1 50%, #1a237e 100%);
      padding: 20px;
    }
    .admin-login-card {
      background: #fff;
      border-radius: 16px;
      padding: 40px 36px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    }
    .admin-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: linear-gradient(135deg, #0d47a1, #1565c0);
      color: #fff;
      padding: 6px 16px;
      border-radius: 50px;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .shield-icon {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, #0d47a1, #1565c0);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      font-size: 2rem;
      color: #fff;
      box-shadow: 0 8px 24px rgba(13,71,161,0.4);
    }
  </style>
</head>
<body class="p-0 m-0">

<div class="admin-login-wrapper">
  <div class="admin-login-card fade-in">

    <!-- Icon -->
    <div class="text-center mb-3">
      <div class="shield-icon">
        <i class="bi bi-shield-lock-fill"></i>
      </div>
      <div class="admin-badge">
        <i class="bi bi-lock-fill"></i> Admin Portal
      </div>
      <div class="login-title" style="font-size:1.4rem;">OMVSAB</div>
      <div class="text-muted small mt-1">Restricted — Authorized Personnel Only</div>
    </div>

    <!-- Flash Messages -->
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 px-3 small">
        <i class="bi bi-check-circle-fill me-1"></i> <%- success_msg %>
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 px-3 small">
        <i class="bi bi-exclamation-triangle-fill me-1"></i> <%= error_msg %>
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Admin Login Form -->
    <form action="/admin/login" method="POST" autocomplete="off">
      <div class="mb-3">
        <label class="form-label fw-semibold">Admin Email</label>
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0">
            <i class="bi bi-person-badge text-muted"></i>
          </span>
          <input type="email" class="form-control border-start-0 ps-0"
                 name="email" placeholder="admin@omvsabsoftware.org"
                 required autocomplete="off">
        </div>
      </div>
      <div class="mb-4">
        <label class="form-label fw-semibold">Password</label>
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0">
            <i class="bi bi-key text-muted"></i>
          </span>
          <input type="password" class="form-control border-start-0 ps-0"
                 name="password" placeholder="••••••••••"
                 required id="adminPass" autocomplete="new-password">
          <button class="btn btn-outline-secondary" type="button"
                  onclick="togglePass('adminPass','eyeIcon')">
            <i class="bi bi-eye" id="eyeIcon"></i>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
        <i class="bi bi-shield-lock me-1"></i>Login as Admin
      </button>
    </form>

    <!-- Back to student login -->
    <div class="text-center mt-3">
      <a href="/login" class="text-muted small">
        <i class="bi bi-arrow-left me-1"></i>Back to Student Login
      </a>
    </div>

    <!-- Footer -->
    <div class="text-center mt-4 pt-3 border-top" style="font-size:0.72rem;color:#aaa;">
      <strong>OMVSAB</strong> · Reg No: OMVSAB-IT-2024<br>
      Karve Nagar, Pune - 411052, Maharashtra, India
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function togglePass(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon  = document.getElementById(iconId);
    if (input.type === 'password') {
      input.type = 'text';
      icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
      input.type = 'password';
      icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
  }
</script>
</body>
</html>
