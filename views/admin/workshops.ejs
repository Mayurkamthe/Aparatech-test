<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'workshops' }) %>
<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div><h1><i class="bi bi-mortarboard me-2"></i>Workshops</h1><p>Manage all workshops and enrollments.</p></div>
      <a href="/admin/workshops/create" class="btn btn-light fw-semibold"><i class="bi bi-plus-circle me-1"></i>Create Workshop</a>
    </div>
  </div>
</div>
<main class="container pb-5">
  <%- include('../partials/flash') %>
  <% if (workshops.length === 0) { %>
    <div class="card"><div class="empty-state"><i class="bi bi-mortarboard"></i><p>No workshops yet.</p><a href="/admin/workshops/create" class="btn btn-primary">Create First Workshop</a></div></div>
  <% } else { %>
  <div class="row g-3">
    <% workshops.forEach(w => { %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="fw-bold mb-0"><%= w.title %></h6>
            <span class="badge <%= w.isActive ? 'bg-success' : 'bg-secondary' %>"><%= w.isActive ? 'Active' : 'Inactive' %></span>
          </div>
          <% if (w.collegeName) { %><p class="text-muted small mb-1"><i class="bi bi-building me-1"></i><%= w.collegeName %></p><% } %>
          <p class="text-muted small mb-1"><i class="bi bi-calendar me-1"></i><%= new Date(w.startDate).toLocaleDateString('en-IN') %> – <%= new Date(w.endDate).toLocaleDateString('en-IN') %></p>
          <p class="text-muted small mb-2"><i class="bi bi-geo-alt me-1"></i><%= w.venue || 'TBD' %></p>
          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="fw-bold text-primary fs-5"><%= w.isFree ? 'FREE' : '₹' + w.fee %></span>
            <span class="badge bg-primary bg-opacity-10 text-primary"><%= w.enrollCount %> enrolled</span>
          </div>
          <div class="d-flex gap-2 flex-wrap">
            <a href="/admin/workshops/<%= w._id %>" class="btn btn-sm btn-primary flex-fill"><i class="bi bi-eye me-1"></i>Manage</a>
            <a href="/admin/workshops/<%= w._id %>/submissions" class="btn btn-sm btn-outline-secondary"><i class="bi bi-file-text"></i></a>
            <a href="/admin/workshops/<%= w._id %>/download" class="btn btn-sm btn-success"><i class="bi bi-download"></i></a>
            <form action="/admin/workshops/<%= w._id %>/delete" method="POST" onsubmit="return confirm('Delete this workshop?')">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
