<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <%- include('../partials/pwa-head') %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/header', { activePage: 'dashboard' }) %>

<!-- Page Header -->
<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h1>
        <p>Welcome back, <%= user.name || 'Administrator' %>! Here's your portal overview.</p>
      </div>
      <a href="/admin/tests/create" class="btn btn-light fw-semibold">
        <i class="bi bi-plus-circle me-1"></i>Create New Test
      </a>
    </div>
  </div>
</div>

<main class="container pb-5">

  <%- include('../partials/flash') %>

  <!--  Stats Row  -->
  <div class="row g-3 mb-4">
    <div class="col-12 col-sm-4 fade-in fade-in-delay-1">
      <div class="stat-card" style="background:linear-gradient(135deg,#0d47a1,#1565c0);">
        <div class="stat-icon"><i class="bi bi-journal-check"></i></div>
        <div>
          <div class="stat-value"><%= stats.testCount %></div>
          <div class="stat-label">Active Tests</div>
        </div>
      </div>
    </div>
    <div class="col-12 col-sm-4 fade-in fade-in-delay-2">
      <div class="stat-card" style="background:linear-gradient(135deg,#00695c,#00897b);">
        <div class="stat-icon"><i class="bi bi-people"></i></div>
        <div>
          <div class="stat-value"><%= stats.studentCount %></div>
          <div class="stat-label">Registered Students</div>
        </div>
      </div>
    </div>
    <div class="col-12 col-sm-4 fade-in fade-in-delay-3">
      <div class="stat-card" style="background:linear-gradient(135deg,#6a1b9a,#8e24aa);">
        <div class="stat-icon"><i class="bi bi-bar-chart-line"></i></div>
        <div>
          <div class="stat-value"><%= stats.resultCount %></div>
          <div class="stat-label">Total Attempts</div>
        </div>
      </div>
    </div>
  </div>

  <!--  Quick Actions  -->
  <div class="row g-3 mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <span class="section-title"><i class="bi bi-lightning-charge me-2"></i>Quick Actions</span>
        </div>
        <div class="card-body">
          <div class="d-flex flex-wrap gap-2">
            <a href="/admin/tests/create" class="btn btn-primary">
              <i class="bi bi-plus-circle me-1"></i>Create Test
            </a>
            <a href="/admin/tests" class="btn btn-outline-primary">
              <i class="bi bi-list-ul me-1"></i>All Tests
            </a>
            <a href="/admin/results" class="btn btn-outline-secondary">
              <i class="bi bi-bar-chart me-1"></i>View Results
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!--  Recent Submissions  -->
  <div class="card fade-in">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span class="section-title"><i class="bi bi-clock-history me-2"></i>Recent Submissions</span>
      <a href="/admin/results" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
      <% if (recentResults.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-inbox"></i>
          <p class="mb-0">No submissions yet. Create a test and share the code with students!</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>Student</th>
                <th>Test</th>
                <th>Score</th>
                <th>Status</th>
                <th>Date</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% recentResults.forEach(r => { %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= r.studentName || '—' %></div>
                  <small class="text-muted"><%= r.studentEmail %></small>
                </td>
                <td>
                  <div class="fw-semibold"><%= r.testTitle %></div>
                  <span class="badge bg-primary bg-opacity-10 text-primary"><%= r.testDomain %></span>
                </td>
                <td>
                  <span class="fw-bold text-mono"><%= r.score %>/<%= r.totalMarks %></span>
                  <div class="progress mt-1" style="height:4px;width:80px;">
                    <div class="progress-bar" style="width:<%= r.percentage %>%"></div>
                  </div>
                </td>
                <td>
                  <% if (r.isPassed) { %>
                    <span class="badge bg-success"><i class="bi bi-check me-1"></i>Passed</span>
                  <% } else { %>
                    <span class="badge bg-danger"><i class="bi bi-x me-1"></i>Failed</span>
                  <% } %>
                </td>
                <td class="text-muted small">
                  <%= new Date(r.submittedAt).toLocaleDateString('en-IN') %>
                </td>
                <td>
                  <a href="/admin/results/<%= r._id %>" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-eye"></i>
                  </a>
                  <a href="/admin/results/<%= r._id %>/pdf" class="btn btn-sm btn-outline-danger ms-1">
                    <i class="bi bi-file-pdf"></i>
                  </a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
