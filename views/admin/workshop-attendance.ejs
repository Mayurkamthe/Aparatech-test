<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
  <style>
    .token-badge {
      font-family: monospace;
      font-size: 1.4rem;
      letter-spacing: 0.2em;
      background: #0d6efd;
      color: #fff;
      padding: 6px 18px;
      border-radius: 8px;
      cursor: pointer;
      user-select: all;
    }
    .session-open  { border-left: 4px solid #198754; }
    .session-closed{ border-left: 4px solid #6c757d; }
  </style>
</head>
<body>
<%- include('../partials/header', { activePage: 'workshops' }) %>

<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1><i class="bi bi-clipboard-check me-2"></i>Attendance</h1>
        <p><%= workshop.title %> · <%= enrolledCount %> enrolled students</p>
      </div>
      <div class="d-flex gap-2">
        <a href="/admin/workshops/<%= workshop._id %>" class="btn btn-light"><i class="bi bi-arrow-left me-1"></i>Back to Workshop</a>
      </div>
    </div>
  </div>
</div>

<main class="container pb-5">
  <%- include('../partials/flash') %>

  <div class="row g-4">

    <!-- Left: Create Session -->
    <div class="col-12 col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-header"><span class="section-title"><i class="bi bi-plus-circle me-2"></i>Create Attendance Session</span></div>
        <div class="card-body">
          <form action="/admin/workshops/<%= workshop._id %>/attendance/create" method="POST">
            <div class="mb-3">
              <label class="form-label fw-semibold">Session Label *</label>
              <input type="text" class="form-control" name="sessionLabel"
                     placeholder="e.g. Day 1 Morning, Module 2..." required>
              <div class="form-text">A unique 6-character token will be auto-generated.</div>
            </div>
            <button type="submit" class="btn btn-primary w-100">
              <i class="bi bi-plus me-1"></i>Create Session
            </button>
          </form>
        </div>
      </div>

      <!-- How it works -->
      <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
          <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2 text-primary"></i>How it works</h6>
          <ol class="small text-muted ps-3 mb-0" style="line-height:1.8;">
            <li>Create a session with a label</li>
            <li>Click <strong>Open</strong> to start the attendance window</li>
            <li>Share the <strong>6-char token</strong> with students verbally or on screen</li>
            <li>Students enter the token in their Workshop Room to mark attendance</li>
            <li>Click <strong>Close</strong> when done — download Excel report anytime</li>
          </ol>
        </div>
      </div>
    </div>

    <!-- Right: Sessions List -->
    <div class="col-12 col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-header">
          <span class="section-title"><i class="bi bi-list-check me-2"></i>Sessions (<%= sessions.length %>)</span>
        </div>
        <div class="card-body p-0">
          <% if (sessions.length === 0) { %>
            <div class="empty-state">
              <i class="bi bi-clipboard-x"></i>
              <p>No sessions yet. Create one to get started.</p>
            </div>
          <% } else { %>
            <div class="list-group list-group-flush">
              <% sessions.forEach(s => { %>
              <div class="list-group-item py-3 <%= s.isOpen ? 'session-open' : 'session-closed' %>">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                  <div>
                    <div class="fw-semibold d-flex align-items-center gap-2">
                      <%= s.sessionLabel %>
                      <% if (s.isOpen) { %>
                        <span class="badge bg-success"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>OPEN</span>
                      <% } else { %>
                        <span class="badge bg-secondary">CLOSED</span>
                      <% } %>
                    </div>
                    <div class="text-muted small mt-1">
                      Created: <%= new Date(s.createdAt).toLocaleString('en-IN') %>
                      <% if (s.openedAt) { %> · Opened: <%= new Date(s.openedAt).toLocaleTimeString('en-IN') %><% } %>
                      <% if (s.closedAt) { %> · Closed: <%= new Date(s.closedAt).toLocaleTimeString('en-IN') %><% } %>
                    </div>
                    <div class="mt-2">
                      <span class="badge bg-primary bg-opacity-10 text-primary me-2">
                        <i class="bi bi-people me-1"></i><%= s.presentCount %> present / <%= enrolledCount %> enrolled
                      </span>
                    </div>
                  </div>

                  <div class="d-flex align-items-center gap-2 flex-wrap">
                    <!-- Token display (only show when open) -->
                    <% if (s.isOpen) { %>
                      <span class="token-badge" title="Click to copy" onclick="copyToken('<%= s.token %>', this)">
                        <%= s.token %>
                      </span>
                    <% } else { %>
                      <code class="text-muted small"><%= s.token %></code>
                    <% } %>

                    <!-- Open / Close toggle -->
                    <% if (!s.isOpen) { %>
                      <form action="/admin/attendance/<%= s._id %>/open" method="POST">
                        <button class="btn btn-sm btn-success">
                          <i class="bi bi-unlock me-1"></i>Open
                        </button>
                      </form>
                    <% } else { %>
                      <form action="/admin/attendance/<%= s._id %>/close" method="POST">
                        <button class="btn btn-sm btn-warning">
                          <i class="bi bi-lock me-1"></i>Close
                        </button>
                      </form>
                    <% } %>

                    <!-- Report -->
                    <a href="/admin/attendance/<%= s._id %>/report" class="btn btn-sm btn-outline-primary">
                      <i class="bi bi-bar-chart me-1"></i>Report
                    </a>

                    <!-- Download -->
                    <a href="/admin/attendance/<%= s._id %>/download" class="btn btn-sm btn-outline-success">
                      <i class="bi bi-download"></i>
                    </a>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function copyToken(token, el) {
    navigator.clipboard.writeText(token).then(() => {
      const orig = el.textContent;
      el.textContent = 'Copied!';
      el.style.background = '#198754';
      setTimeout(() => { el.textContent = orig; el.style.background = ''; }, 1500);
    });
  }
</script>
</body>
</html>
