<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'results' }) %>

<div class="page-header">
  <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h1><i class="bi bi-file-person me-2"></i>Result Detail</h1>
      <p><%= result.studentEmail %> — <%= result.testTitle %></p>
    </div>
    <div class="d-flex gap-2">
      <a href="/admin/results/<%= result._id %>/pdf" class="btn btn-danger fw-semibold">
        <i class="bi bi-file-pdf me-1"></i>Download PDF
      </a>
      <a href="/admin/results" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Back
      </a>
    </div>
  </div>
</div>

<main class="container pb-5">
  <%- include('../partials/flash') %>

  <div class="row g-4">

    <!-- Summary Card -->
    <div class="col-12 col-md-4">
      <div class="card h-100">
        <div class="card-header">
          <span class="section-title"><i class="bi bi-person-circle me-2"></i>Summary</span>
        </div>
        <div class="card-body">

          <!-- Score Ring -->
          <div class="text-center mb-4">
            <div class="score-circle mx-auto mb-2"
                 style="background:<%= result.isPassed ? 'var(--success-light)' : 'var(--danger-light)' %>;
                        border-color:<%= result.isPassed ? 'var(--success)' : 'var(--danger)' %>;">
              <div class="score-value" style="color:<%= result.isPassed ? 'var(--success)' : 'var(--danger)' %>;">
                <%= result.score %>
              </div>
              <div class="score-total text-muted">of <%= result.totalMarks %></div>
            </div>
            <h4 class="fw-bold" style="color:<%= result.isPassed ? 'var(--success)' : 'var(--danger)' %>;">
              <%= result.percentage.toFixed(1) %>%
            </h4>
            <span class="badge fs-6 <%= result.isPassed ? 'bg-success' : 'bg-danger' %>">
              <%= result.isPassed ? '✓ PASSED' : '✗ FAILED' %>
            </span>
          </div>

          <!-- Stats -->
          <div class="row g-2 text-center mb-3">
            <div class="col-4">
              <div class="p-2 rounded-2 bg-success bg-opacity-10">
                <div class="fw-bold text-success fs-5"><%= result.correctCount %></div>
                <div class="text-muted" style="font-size:0.72rem;">Correct</div>
              </div>
            </div>
            <div class="col-4">
              <div class="p-2 rounded-2 bg-danger bg-opacity-10">
                <div class="fw-bold text-danger fs-5"><%= result.incorrectCount %></div>
                <div class="text-muted" style="font-size:0.72rem;">Wrong</div>
              </div>
            </div>
            <div class="col-4">
              <div class="p-2 rounded-2 bg-warning bg-opacity-10">
                <div class="fw-bold text-warning fs-5"><%= result.unattempted %></div>
                <div class="text-muted" style="font-size:0.72rem;">Skipped</div>
              </div>
            </div>
          </div>

          <table class="table table-sm table-borderless small">
            <tr><td class="text-muted">Student</td><td class="fw-semibold"><%= result.studentName || '—' %></td></tr>
            <tr><td class="text-muted">Email</td><td><%= result.studentEmail %></td></tr>
            <tr><td class="text-muted">Test</td><td class="fw-semibold"><%= result.testTitle %></td></tr>
            <tr><td class="text-muted">Domain</td><td><%= result.testDomain %></td></tr>
            <tr><td class="text-muted">Submitted</td><td><%= new Date(result.submittedAt).toLocaleString('en-IN') %></td></tr>
            <tr><td class="text-muted">Time Taken</td>
                <td><%= Math.floor(result.timeTaken/60) %>m <%= result.timeTaken%60 %>s</td></tr>
            <tr><td class="text-muted">Tab Switches</td>
                <td><span class="badge <%= result.tabSwitchCount >= 3 ? 'bg-danger' : 'bg-secondary' %>">
                  <%= result.tabSwitchCount %>
                </span></td></tr>
          </table>
        </div>
      </div>
    </div>

    <!-- Answers Detail -->
    <div class="col-12 col-md-8">
      <div class="card">
        <div class="card-header">
          <span class="section-title"><i class="bi bi-list-check me-2"></i>Answers Detail</span>
        </div>
        <div class="card-body p-3 d-flex flex-column gap-3">
          <% result.answers.forEach((ans, idx) => { %>
          <div class="border rounded-2 p-3
               <%= ans.isCorrect ? 'border-success border-opacity-25' : ans.selectedOption === -1 ? 'border-warning border-opacity-25' : 'border-danger border-opacity-25' %>">
            <div class="d-flex gap-2 mb-2">
              <span class="question-number">Q<%= idx + 1 %></span>
              <% if (ans.isCorrect) { %>
                <span class="badge bg-success ms-auto"><i class="bi bi-check me-1"></i>Correct</span>
              <% } else if (ans.selectedOption === -1) { %>
                <span class="badge bg-warning text-dark ms-auto">Skipped</span>
              <% } else { %>
                <span class="badge bg-danger ms-auto"><i class="bi bi-x me-1"></i>Wrong</span>
              <% } %>
            </div>
            <p class="question-text mb-2"><%= ans.questionText %></p>
            <div class="d-flex flex-column gap-1">
              <% if (ans.options && ans.options.length) { %>
                <% ans.options.forEach((opt, oIdx) => { %>
                <div class="d-flex align-items-center gap-2 rounded px-2 py-1 small
                     <%= oIdx === ans.correctOption ? 'bg-success bg-opacity-10' :
                         oIdx === ans.selectedOption ? 'bg-danger bg-opacity-10' : 'bg-light' %>">
                  <span class="badge <%= oIdx === ans.correctOption ? 'bg-success' : oIdx === ans.selectedOption ? 'bg-danger' : 'bg-secondary' %>"
                        style="width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:0.65rem;">
                    <%= ['A','B','C','D'][oIdx] %>
                  </span>
                  <span><%= opt %></span>
                  <% if (oIdx === ans.correctOption) { %>
                    <i class="bi bi-check-circle-fill text-success ms-auto"></i>
                  <% } %>
                  <% if (oIdx === ans.selectedOption && !ans.isCorrect) { %>
                    <i class="bi bi-x-circle-fill text-danger ms-auto"></i>
                  <% } %>
                </div>
                <% }) %>
              <% } %>
            </div>
            <% if (ans.explanation) { %>
            <div class="mt-2 text-muted small">
              <i class="bi bi-lightbulb text-warning me-1"></i><%= ans.explanation %>
            </div>
            <% } %>
            <div class="text-end mt-1 small text-muted">
              Marks: <strong><%= ans.marksAwarded %></strong>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
