<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'colleges' }) %>

<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1><i class="bi bi-building me-2"></i>Manage Colleges</h1>
        <p>Add colleges and view grouped reports.</p>
      </div>
      <button class="btn btn-light fw-semibold" data-bs-toggle="modal" data-bs-target="#addCollegeModal">
        <i class="bi bi-plus-circle me-1"></i>Add College
      </button>
    </div>
  </div>
</div>

<main class="container pb-5">
  <%- include('../partials/flash') %>

  <% if (colleges.length === 0) { %>
    <div class="card">
      <div class="empty-state">
        <i class="bi bi-building"></i>
        <p class="mb-2">No colleges added yet.</p>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCollegeModal">
          <i class="bi bi-plus-circle me-1"></i>Add First College
        </button>
      </div>
    </div>
  <% } else { %>
  <div class="row g-3">
    <% colleges.forEach(c => { %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
              <h6 class="fw-bold mb-0"><%= c.name %></h6>
              <span class="badge bg-primary bg-opacity-10 text-primary small"><%= c.code %></span>
            </div>
            <span class="badge <%= c.isActive ? 'bg-success' : 'bg-secondary' %>">
              <%= c.isActive ? 'Active' : 'Inactive' %>
            </span>
          </div>
          <% if (c.address) { %>
            <p class="text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i><%= c.address %></p>
          <% } %>
          <% if (c.contactEmail) { %>
            <p class="text-muted small mb-2"><i class="bi bi-envelope me-1"></i><%= c.contactEmail %></p>
          <% } %>
          <div class="row g-2 text-center mt-2 mb-3">
            <div class="col-6">
              <div class="bg-light rounded p-2">
                <div class="fw-bold text-primary fs-5"><%= c.studentCount %></div>
                <div class="text-muted" style="font-size:0.72rem;">Students</div>
              </div>
            </div>
            <div class="col-6">
              <div class="bg-light rounded p-2">
                <div class="fw-bold text-success fs-5"><%= c.resultCount %></div>
                <div class="text-muted" style="font-size:0.72rem;">Results</div>
              </div>
            </div>
          </div>
          <div class="d-flex gap-2">
            <a href="/admin/colleges/<%= c._id %>/report" class="btn btn-sm btn-primary flex-fill">
              <i class="bi bi-bar-chart me-1"></i>Report
            </a>
            <a href="/admin/colleges/<%= c._id %>/download" class="btn btn-sm btn-success flex-fill">
              <i class="bi bi-download me-1"></i>Excel
            </a>
            <button class="btn btn-sm btn-outline-danger"
                    onclick="confirmDeleteCollege('<%= c._id %>', '<%= c.name %>', <%= c.studentCount %>)">
              <i class="bi bi-trash"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</main>

<!-- Add College Modal -->
<div class="modal fade" id="addCollegeModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title"><i class="bi bi-building me-2"></i>Add New College</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/colleges/add" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">College Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="name" placeholder="e.g. MIT College of Engineering" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Short Code</label>
            <input type="text" class="form-control" name="code" placeholder="e.g. MITCOE" maxlength="10">
            <small class="text-muted">Auto-generated if left blank</small>
          </div>
          <div class="mb-3">
            <label class="form-label">Address</label>
            <input type="text" class="form-control" name="address" placeholder="City, State">
          </div>
          <div class="mb-3">
            <label class="form-label">Contact Email</label>
            <input type="email" class="form-control" name="contactEmail" placeholder="principal@college.edu">
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add College
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteCollegeModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete College</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Delete <strong id="deleteCollegeName"></strong>?</p>
        <div class="alert alert-warning small py-2" id="deleteCollegeWarning"></div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <form id="deleteCollegeForm" method="POST">
          <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function confirmDeleteCollege(id, name, studentCount) {
    document.getElementById('deleteCollegeName').textContent = name;
    document.getElementById('deleteCollegeWarning').textContent =
      studentCount > 0
        ? ` ${studentCount} student(s) will be unlinked from this college.`
        : 'No students are linked to this college.';
    document.getElementById('deleteCollegeForm').action = '/admin/colleges/' + id + '/delete';
    new bootstrap.Modal(document.getElementById('deleteCollegeModal')).show();
  }
</script>
</body>
</html>
