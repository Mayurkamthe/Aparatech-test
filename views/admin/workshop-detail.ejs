<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'workshops' }) %>
<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1><i class="bi bi-mortarboard me-2"></i><%= workshop.title %></h1>
        <p><%= workshop.collegeName || 'All Colleges' %> · <%= new Date(workshop.startDate).toLocaleDateString('en-IN') %></p>
      </div>
      <div class="d-flex gap-2">
        <a href="/admin/workshops/<%= workshop._id %>/submissions" class="btn btn-outline-light"><i class="bi bi-file-text me-1"></i>Submissions</a>
        <a href="/admin/workshops/<%= workshop._id %>/download" class="btn btn-success"><i class="bi bi-download me-1"></i>Excel</a>
        <a href="/admin/workshops" class="btn btn-light"><i class="bi bi-arrow-left me-1"></i>Back</a>
      </div>
    </div>
  </div>
</div>
<main class="container pb-5">
  <%- include('../partials/flash') %>
  <div class="row g-4">

    <!-- Left: Add Material -->
    <div class="col-12 col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-header"><span class="section-title"><i class="bi bi-plus-circle me-2"></i>Add Material / Task</span></div>
        <div class="card-body">
          <form action="/admin/workshops/<%= workshop._id %>/material" method="POST">
            <div class="mb-3">
              <label class="form-label">Title *</label>
              <input type="text" class="form-control" name="title" required placeholder="e.g. Day 1 Notes">
            </div>
            <div class="mb-3">
              <label class="form-label">Type</label>
              <select class="form-select" name="type" id="matType" onchange="toggleTaskFields(this.value)">
                <option value="notes">📄 Notes</option>
                <option value="video">🎥 Video Link</option>
                <option value="link">🔗 Resource Link</option>
                <option value="task">📝 Task</option>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label">Content / URL</label>
              <textarea class="form-control" name="content" rows="3" placeholder="Paste notes text or URL here..."></textarea>
            </div>
            <div class="mb-3">
              <label class="form-label">File URL <small class="text-muted">(Google Drive / Dropbox link)</small></label>
              <input type="url" class="form-control" name="fileUrl" placeholder="https://...">
            </div>
            <div id="taskFields" style="display:none;">
              <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" name="isTask" id="isTaskChk">
                <label class="form-check-label">This is a Task (requires submission)</label>
              </div>
              <div class="mb-3">
                <label class="form-label">Task Deadline</label>
                <input type="datetime-local" class="form-control" name="taskDeadline">
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Order</label>
              <input type="number" class="form-control" name="order" value="0" min="0">
            </div>
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus me-1"></i>Add</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Right: Enrollments + Materials -->
    <div class="col-12 col-lg-8">

      <!-- Stats -->
      <div class="row g-3 mb-4">
        <div class="col-4">
          <div class="card text-center p-3 border-0 shadow-sm">
            <div class="fw-bold fs-3 text-primary"><%= enrollments.length %></div>
            <div class="text-muted small">Enrolled</div>
          </div>
        </div>
        <div class="col-4">
          <div class="card text-center p-3 border-0 shadow-sm">
            <div class="fw-bold fs-3 text-success"><%= workshop.isFree ? 'FREE' : '₹' + workshop.fee %></div>
            <div class="text-muted small">Fee</div>
          </div>
        </div>
        <div class="col-4">
          <div class="card text-center p-3 border-0 shadow-sm">
            <div class="fw-bold fs-3 text-warning"><%= materials.length %></div>
            <div class="text-muted small">Materials</div>
          </div>
        </div>
      </div>

      <!-- Materials List -->
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header"><span class="section-title"><i class="bi bi-folder me-2"></i>Study Materials & Tasks</span></div>
        <div class="card-body p-0">
          <% if (materials.length === 0) { %>
            <div class="empty-state"><i class="bi bi-folder-x"></i><p>No materials added yet.</p></div>
          <% } else { %>
          <div class="list-group list-group-flush">
            <% materials.forEach(m => { %>
            <div class="list-group-item d-flex align-items-center gap-3 py-3">
              <div class="fs-4">
                <% if (m.type === 'notes') { %>📄
                <% } else if (m.type === 'video') { %>🎥
                <% } else if (m.type === 'link') { %>🔗
                <% } else { %>📝<% } %>
              </div>
              <div class="flex-grow-1">
                <div class="fw-semibold"><%= m.title %></div>
                <div class="text-muted small"><%= m.type.toUpperCase() %><%= m.isTask ? ' · TASK' : '' %></div>
              </div>
              <% if (m.fileUrl) { %>
                <a href="<%= m.fileUrl %>" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-download"></i></a>
              <% } %>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Enrollments -->
      <div class="card border-0 shadow-sm">
        <div class="card-header"><span class="section-title"><i class="bi bi-people me-2"></i>Enrolled Students (<%= enrollments.length %>)</span></div>
        <div class="card-body p-0">
          <% if (enrollments.length === 0) { %>
            <div class="empty-state"><i class="bi bi-person-x"></i><p>No enrollments yet.</p></div>
          <% } else { %>
          <div class="table-responsive">
            <table class="table mb-0">
              <thead><tr><th>#</th><th>Student</th><th>College</th><th>Fee</th><th>Payment</th><th>Date</th></tr></thead>
              <tbody>
                <% enrollments.forEach((e, i) => { %>
                <tr>
                  <td class="text-muted small"><%= i+1 %></td>
                  <td><div class="fw-semibold small"><%= e.studentName || '—' %></div><div class="text-muted" style="font-size:0.75rem;"><%= e.studentEmail %></div></td>
                  <td class="small"><%= e.collegeName || '—' %></td>
                  <td class="small">₹<%= e.fee %></td>
                  <td><span class="badge <%= e.paymentStatus === 'paid' ? 'bg-success' : e.paymentStatus === 'free' ? 'bg-info' : 'bg-warning text-dark' %>"><%= e.paymentStatus %></span></td>
                  <td class="text-muted small"><%= new Date(e.enrolledAt).toLocaleDateString('en-IN') %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function toggleTaskFields(type) {
    document.getElementById('taskFields').style.display = type === 'task' ? 'block' : 'none';
    if (type === 'task') document.getElementById('isTaskChk').checked = true;
  }
</script>
</body></html>
