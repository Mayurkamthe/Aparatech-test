<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'tests' }) %>

<div class="page-header">
  <div class="container">
    <h1><i class="bi bi-plus-circle me-2"></i>Create New Test</h1>
    <p>Fill in the details to create a new assessment test.</p>
  </div>
</div>

<main class="container pb-5" style="max-width:720px;">
  <%- include('../partials/flash') %>

  <div class="card">
    <div class="card-header">
      <span class="section-title"><i class="bi bi-file-earmark-text me-2"></i>Test Configuration</span>
    </div>
    <div class="card-body p-4">
      <form action="/admin/tests/create" method="POST" id="createTestForm">

        <div class="row g-3">
          <!-- Title -->
          <div class="col-12">
            <label class="form-label">Test Title <span class="text-danger">*</span></label>
            <input type="text" name="title" class="form-control"
                   placeholder="e.g. JavaScript Fundamentals Assessment"
                   required maxlength="120">
            <div class="form-text">A descriptive title shown to students.</div>
          </div>

          <!-- Domain -->
          <div class="col-12 col-md-6">
            <label class="form-label">Domain / Category <span class="text-danger">*</span></label>
            <select name="domain" class="form-select" required>
              <option value="" disabled selected>Select domain...</option>
              <option value="Frontend">Frontend Development</option>
              <option value="Backend">Backend Development</option>
              <option value="Database">Database Management</option>
              <option value="Full Stack">Full Stack Development</option>
              <option value="DevOps">DevOps & Cloud</option>
              <option value="General">General Knowledge</option>
            </select>
          </div>

          <!-- Duration -->
          <div class="col-12 col-md-6">
            <label class="form-label">Duration (minutes) <span class="text-danger">*</span></label>
            <input type="number" name="duration" class="form-control"
                   placeholder="30" min="5" max="180" required>
            <div class="form-text">Min: 5 min | Max: 180 min</div>
          </div>

          <!-- Total Marks -->
          <div class="col-12 col-md-6">
            <label class="form-label">Total Marks <span class="text-danger">*</span></label>
            <input type="number" name="totalMarks" class="form-control"
                   placeholder="50" min="1" required>
          </div>

          <!-- Passing Marks -->
          <div class="col-12 col-md-6">
            <label class="form-label">Passing Marks</label>
            <input type="number" name="passingMarks" class="form-control"
                   placeholder="25" min="0" value="0">
            <div class="form-text">Set 0 to use default 40%.</div>
          </div>

          <!-- Question Limit -->
          <div class="col-12">
            <label class="form-label">Question Limit</label>
            <input type="number" name="questionLimit" class="form-control"
                   placeholder="0 (= all questions)" min="0" value="0">
            <div class="form-text">
              If you add 30 questions but set limit to 20, each student gets 20 randomly selected.
              Set 0 to use all questions.
            </div>
          </div>

          <!-- Instructions -->
          <div class="col-12">
            <label class="form-label">Test Instructions (optional)</label>
            <textarea name="instructions" class="form-control" rows="3"
                      placeholder="e.g. Read each question carefully. No negative marking. Mobile not allowed."></textarea>
          </div>

          <!-- Scheduled Window -->
          <div class="col-12">
            <hr class="my-2">
            <div class="form-check form-switch mb-3">
              <input class="form-check-input" type="checkbox" name="isScheduled" id="isScheduled"
                     onchange="toggleSchedule(this.checked)">
              <label class="form-check-label fw-semibold" for="isScheduled">
                <i class="bi bi-clock me-1"></i>Schedule a Time Window
              </label>
              <div class="form-text">Enable to restrict when students can attempt this test.</div>
            </div>

            <div id="scheduleFields" style="display:none;">
              <div class="alert alert-info border-0 py-2 small mb-3">
                <i class="bi bi-info-circle me-1"></i>
                Students can only enter the test code and start the test within this window.
                Outside this window the test is inaccessible even with the correct code.
              </div>
              <div class="row g-3">
                <div class="col-12 col-md-6">
                  <label class="form-label">Window Opens <span class="text-danger">*</span></label>
                  <input type="datetime-local" name="scheduledStart" id="scheduledStart" class="form-control">
                </div>
                <div class="col-12 col-md-6">
                  <label class="form-label">Window Closes <span class="text-danger">*</span></label>
                  <input type="datetime-local" name="scheduledEnd" id="scheduledEnd" class="form-control">
                </div>
              </div>
            </div>
          </div>
        </div>

        <hr class="my-4">

        <div class="d-flex gap-2 justify-content-end">
          <a href="/admin/tests" class="btn btn-outline-secondary">Cancel</a>
          <button type="submit" class="btn btn-primary px-4" id="submitBtn">
            <i class="bi bi-save me-1"></i>Create Test & Add Questions
          </button>
        </div>

      </form>
    </div>
  </div>

</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function toggleSchedule(on) {
    document.getElementById('scheduleFields').style.display = on ? 'block' : 'none';
    document.getElementById('scheduledStart').required = on;
    document.getElementById('scheduledEnd').required   = on;
  }
  document.getElementById('createTestForm').addEventListener('submit', function () {
    const btn = document.getElementById('submitBtn');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Creating...';
    btn.disabled = true;
  });
</script>
</body>
</html>
