<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/header', { activePage: 'users' }) %>

<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1><i class="bi bi-people me-2"></i>Manage Users</h1>
        <p>View, contact and delete registered students.</p>
      </div>
      <div class="d-flex align-items-center gap-2">
        <span class="badge bg-light text-dark fs-6 px-3 py-2">
          <i class="bi bi-person-check me-1"></i><%= users.length %> Students
        </span>
        <button class="btn btn-success" onclick="openWaTemplateModal()">
          <i class="bi bi-whatsapp me-1"></i>WA Template
        </button>
        <% if (users.length > 0) { %>
        <button class="btn btn-danger" onclick="confirmDeleteAll(<%= users.length %>)">
          <i class="bi bi-trash me-1"></i>Delete All
        </button>
        <% } %>
      </div>
    </div>
  </div>
</div>

<main class="container pb-5">
  <%- include('../partials/flash') %>

  <!-- Search -->
  <div class="card mb-4">
    <div class="card-body">
      <form method="GET" action="/admin/users" class="d-flex gap-2 flex-wrap">
        <div class="input-group" style="max-width:400px;">
          <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
          <input type="text" class="form-control" name="search"
                 placeholder="Search by name, email or college..."
                 value="<%= search %>">
        </div>
        <button type="submit" class="btn btn-primary">Search</button>
        <% if (search) { %>
          <a href="/admin/users" class="btn btn-outline-secondary">Clear</a>
        <% } %>
      </form>
    </div>
  </div>

  <!-- Users Table -->
  <div class="card">
    <div class="card-header">
      <span class="section-title"><i class="bi bi-table me-2"></i>Student List</span>
    </div>
    <div class="card-body p-0">
      <% if (users.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-person-x"></i>
          <p class="mb-0">No students found.</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Mobile</th>
                <th>College</th>
                <th>Attempts</th>
                <th>Joined</th>
                <th>Contact</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((u, i) => { %>
              <tr>
                <td class="text-muted small"><%= i + 1 %></td>
                <td>
                  <div class="fw-semibold"><%= u.name || '—' %></div>
                </td>
                <td class="text-muted small"><%= u.email %></td>
                <td class="small"><%= u.mobile || '—' %></td>
                <td class="small"><%= u.collegeName || '—' %></td>
                <td>
                  <span class="badge bg-primary bg-opacity-10 text-primary">
                    <%= u.attempts %> test<%= u.attempts !== 1 ? 's' : '' %>
                  </span>
                </td>
                <td class="text-muted small">
                  <%= new Date(u.createdAt).toLocaleDateString('en-IN') %>
                </td>
                <td>
                  <% if (u.mobile) { %>
                    <div class="d-flex gap-1">
                      <a href="tel:<%= u.mobile %>"
                         class="btn btn-sm btn-outline-primary"
                         title="Call <%= u.name %>">
                        <i class="bi bi-telephone"></i>
                      </a>
                      <button class="btn btn-sm btn-success"
                              title="WhatsApp <%= u.name %>"
                              onclick="openWaModal('<%= u.mobile %>', '<%= (u.name || '').replace(/'/g, '') %>')">
                        <i class="bi bi-whatsapp"></i>
                      </button>
                    </div>
                  <% } else { %>
                    <span class="text-muted small">No mobile</span>
                  <% } %>
                </td>
                <td>
                  <button class="btn btn-sm btn-outline-danger"
                          onclick="confirmDelete('<%= u._id %>', '<%= u.name || u.email %>', <%= u.attempts %>)">
                    <i class="bi bi-trash"></i> Delete
                  </button>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</main>

<!-- ══════════════════════════════════════════════ -->
<!-- WhatsApp Send Modal                           -->
<!-- ══════════════════════════════════════════════ -->
<div class="modal fade" id="waModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0" style="background:#25D366;color:#fff;">
        <h5 class="modal-title"><i class="bi bi-whatsapp me-2"></i>Send WhatsApp Message</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="small text-muted mb-1">Sending to: <strong id="waRecipientName"></strong> (<span id="waRecipientNum"></span>)</p>
        <label class="form-label fw-semibold mt-2">Message</label>
        <textarea id="waMessage" class="form-control" rows="5" placeholder="Type your message..."></textarea>
        <div class="form-text">Use <code>{name}</code> — it will be replaced with the student's name.</div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-success" onclick="sendWhatsApp()">
          <i class="bi bi-whatsapp me-1"></i>Open WhatsApp
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════ -->
<!-- WA Template Edit Modal                        -->
<!-- ══════════════════════════════════════════════ -->
<div class="modal fade" id="waTemplateModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0" style="background:#128C7E;color:#fff;">
        <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Edit Default WA Template</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/users/wa-template" method="POST">
        <div class="modal-body">
          <label class="form-label fw-semibold">Default Message Template</label>
          <textarea name="template" id="waTemplateInput" class="form-control" rows="6"
                    placeholder="Hi {name}, ..."></textarea>
          <div class="form-text mt-1">
            Use <code>{name}</code> to insert the student's name automatically when sending.
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success">
            <i class="bi bi-save me-1"></i>Save Template
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to delete <strong id="deleteUserName"></strong>?</p>
        <div class="alert alert-warning small py-2" id="deleteWarning"></div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <form id="deleteForm" method="POST">
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>Yes, Delete
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Delete All Modal -->
<div class="modal fade" id="deleteAllModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete All Students</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-danger">
          <strong> This action cannot be undone!</strong>
        </div>
        <p>You are about to delete <strong id="deleteAllCount"></strong> students and <strong>all their test results</strong>.</p>
        <p class="text-muted small">Type <strong>DELETE</strong> below to confirm:</p>
        <input type="text" class="form-control" id="deleteAllConfirmInput" placeholder="Type DELETE to confirm">
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <form action="/admin/users/delete-all" method="POST" id="deleteAllForm">
          <button type="submit" class="btn btn-danger" id="deleteAllBtn" disabled>
            <i class="bi bi-trash me-1"></i>Delete All Students
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // ── WA state ──────────────────────────────────────────
  let _currentWaMobile = '';
  let _currentWaName   = '';
  let _waTemplate      = '';

  // Load saved template from server on page load
  fetch('/admin/users/wa-template')
    .then(r => r.json())
    .then(d => { _waTemplate = d.template || ''; });

  // Open WA send modal for a specific student
  function openWaModal(mobile, name) {
    _currentWaMobile = mobile;
    _currentWaName   = name;
    document.getElementById('waRecipientName').textContent = name || mobile;
    document.getElementById('waRecipientNum').textContent  = mobile;
    // Pre-fill with template, replacing {name}
    document.getElementById('waMessage').value = _waTemplate.replace(/\{name\}/g, name);
    new bootstrap.Modal(document.getElementById('waModal')).show();
  }

  // Open WhatsApp with the typed message
  function sendWhatsApp() {
    const msg    = document.getElementById('waMessage').value.trim();
    const mobile = _currentWaMobile.replace(/\D/g, '');
    // Indian numbers: prepend 91 if 10 digits
    const intl   = mobile.length === 10 ? '91' + mobile : mobile;
    const url    = 'https://wa.me/' + intl + '?text=' + encodeURIComponent(msg);
    window.open(url, '_blank');
    bootstrap.Modal.getInstance(document.getElementById('waModal')).hide();
  }

  // Open WA template editor — pre-fill with current template
  function openWaTemplateModal() {
    document.getElementById('waTemplateInput').value = _waTemplate;
    new bootstrap.Modal(document.getElementById('waTemplateModal')).show();
  }

  // ── Delete helpers ────────────────────────────────────
  function confirmDeleteAll(count) {
    document.getElementById('deleteAllCount').textContent = count;
    document.getElementById('deleteAllConfirmInput').value = '';
    document.getElementById('deleteAllBtn').disabled = true;
    new bootstrap.Modal(document.getElementById('deleteAllModal')).show();
  }

  document.addEventListener('input', function(e) {
    if (e.target.id === 'deleteAllConfirmInput') {
      document.getElementById('deleteAllBtn').disabled = e.target.value !== 'DELETE';
    }
  });

  function confirmDelete(id, name, attempts) {
    document.getElementById('deleteUserName').textContent = name;
    document.getElementById('deleteWarning').textContent =
      attempts > 0
        ? ` This will also delete ${attempts} test result(s) for this student.`
        : 'This student has no test results.';
    document.getElementById('deleteForm').action = '/admin/users/' + id + '/delete';
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
  }
</script>
</body>
</html>
