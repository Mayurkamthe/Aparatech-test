<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'announce' }) %>

<div class="page-header">
  <div class="container">
    <h1><i class="bi bi-megaphone me-2"></i>Send Announcement</h1>
    <p>Send an email to all students or a specific college.</p>
  </div>
</div>

<main class="container pb-5" style="max-width:760px;">
  <%- include('../partials/flash') %>

  <div class="card">
    <div class="card-header">
      <span class="section-title"><i class="bi bi-envelope me-2"></i>Compose Announcement</span>
    </div>
    <div class="card-body p-4">
      <form action="/admin/announce" method="POST" id="announceForm">

        <!-- Audience -->
        <div class="mb-4">
          <label class="form-label fw-semibold">Send To <span class="text-danger">*</span></label>
          <div class="d-flex gap-3 flex-wrap">
            <div class="form-check">
              <input class="form-check-input" type="radio" name="audience"
                     id="audAll" value="all" checked onchange="toggleCollege()">
              <label class="form-check-label" for="audAll">
                <i class="bi bi-people me-1"></i>All Students
                <span class="badge bg-secondary ms-1"><%= studentCount %></span>
              </label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="audience"
                     id="audCollege" value="college" onchange="toggleCollege()">
              <label class="form-check-label" for="audCollege">
                <i class="bi bi-building me-1"></i>Specific College
              </label>
            </div>
          </div>

          <!-- College selector (hidden by default) -->
          <div class="mt-3" id="collegeSelector" style="display:none;">
            <select name="collegeId" class="form-select" id="collegeSelect">
              <option value="" disabled selected>Select a college...</option>
              <% colleges.forEach(c => { %>
              <option value="<%= c._id %>"><%= c.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <!-- Subject -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Subject <span class="text-danger">*</span></label>
          <input type="text" name="subject" class="form-control"
                 placeholder="e.g. Important: Upcoming Test Schedule Update"
                 maxlength="150" required>
        </div>

        <!-- Message -->
        <div class="mb-4">
          <label class="form-label fw-semibold">Message <span class="text-danger">*</span></label>
          <textarea name="message" class="form-control" rows="8"
                    placeholder="Write your announcement here. Line breaks are preserved in the email."
                    required id="messageBox"></textarea>
          <div class="d-flex justify-content-between mt-1">
            <div class="form-text">The greeting "Dear Student," and your sign-off are added automatically.</div>
            <div class="form-text text-end"><span id="charCount">0</span> characters</div>
          </div>
        </div>

        <!-- Preview box -->
        <div class="card bg-light border-0 mb-4" id="previewBox" style="display:none;">
          <div class="card-body">
            <div class="text-muted small fw-semibold mb-2 text-uppercase" style="letter-spacing:.5px;">Preview</div>
            <p class="mb-1 small">Dear Student,</p>
            <p class="mb-1 small" id="previewText" style="white-space:pre-wrap;"></p>
            <p class="mb-0 small text-muted">Regards, <strong><%= locals.user ? user.name : 'Admin' %></strong></p>
          </div>
        </div>

        <div class="d-flex gap-2 justify-content-between align-items-center flex-wrap">
          <button type="button" class="btn btn-outline-secondary" onclick="togglePreview()">
            <i class="bi bi-eye me-1"></i>Preview
          </button>
          <div class="d-flex gap-2">
            <a href="/admin/dashboard" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary fw-semibold px-4" id="sendBtn">
              <i class="bi bi-send me-1"></i>Send Announcement
            </button>
          </div>
        </div>

      </form>
    </div>
  </div>

  <!-- Info card -->
  <div class="card mt-3 border-0 bg-light">
    <div class="card-body py-3">
      <div class="d-flex gap-3 align-items-start">
        <i class="bi bi-info-circle text-primary mt-1"></i>
        <div class="small text-muted">
          Emails are sent in batches in the background. Large audiences may take a few minutes.
          Students receive the email from the portal's configured SMTP address.
        </div>
      </div>
    </div>
  </div>

</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const msgBox = document.getElementById('messageBox');

  msgBox.addEventListener('input', () => {
    document.getElementById('charCount').textContent = msgBox.value.length;
    document.getElementById('previewText').textContent = msgBox.value;
  });

  function toggleCollege() {
    const sel = document.getElementById('collegeSelector');
    const isCollege = document.getElementById('audCollege').checked;
    sel.style.display = isCollege ? 'block' : 'none';
    document.getElementById('collegeSelect').required = isCollege;
  }

  let previewVisible = false;
  function togglePreview() {
    previewVisible = !previewVisible;
    const box = document.getElementById('previewBox');
    box.style.display = previewVisible ? 'block' : 'none';
    document.getElementById('previewText').textContent = msgBox.value;
  }

  document.getElementById('announceForm').addEventListener('submit', function () {
    const btn = document.getElementById('sendBtn');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending...';
    btn.disabled = true;
  });
</script>
</body>
</html>
