<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'tests' }) %>

<div class="page-header">
  <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h1><i class="bi bi-journal-check me-2"></i>Manage Tests</h1>
      <p>Create and manage all assessment tests.</p>
    </div>
    <a href="/admin/tests/create" class="btn btn-light fw-semibold">
      <i class="bi bi-plus-circle me-1"></i>New Test
    </a>
  </div>
</div>

<main class="container pb-5">
  <%- include('../partials/flash') %>

  <% if (tests.length === 0) { %>
    <div class="card"><div class="card-body empty-state">
      <i class="bi bi-journal-x"></i>
      <h5>No tests created yet</h5>
      <p class="text-muted">Create your first test to get started.</p>
      <a href="/admin/tests/create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Create First Test
      </a>
    </div></div>
  <% } else { %>
    <div class="row g-3">
      <% tests.forEach(test => { %>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="badge bg-primary bg-opacity-10 text-primary"><%= test.domain %></span>
              <div class="d-flex gap-1">
                <% if (test.isScheduled) { %>
                  <% const now = new Date(); %>
                  <% if (now < test.scheduledStart) { %>
                    <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Scheduled</span>
                  <% } else if (now > test.scheduledEnd) { %>
                    <span class="badge bg-secondary"><i class="bi bi-clock-history me-1"></i>Ended</span>
                  <% } else { %>
                    <span class="badge bg-success"><i class="bi bi-circle-fill me-1" style="font-size:0.45rem;"></i>Live Now</span>
                  <% } %>
                <% } %>
                <% if (test.isActive) { %>
                  <span class="badge bg-success">Active</span>
                <% } else { %>
                  <span class="badge bg-secondary">Inactive</span>
                <% } %>
              </div>
            </div>
            <h5 class="fw-bold mb-1"><%= test.title %></h5>
            <div class="code-badge mb-2"><i class="bi bi-key me-1"></i><%= test.code %></div>

            <% if (test.isScheduled && test.scheduledStart && test.scheduledEnd) { %>
            <div class="alert alert-warning border-0 py-2 px-3 mb-2" style="font-size:0.78rem;">
              <i class="bi bi-calendar-clock me-1"></i>
              <strong>Window:</strong>
              <%= new Date(test.scheduledStart).toLocaleString('en-IN', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %>
              → <%= new Date(test.scheduledEnd).toLocaleString('en-IN', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %>
            </div>
            <% } %>

            <div class="row g-2 mb-3">
              <div class="col-6">
                <div class="bg-light rounded-2 p-2 text-center">
                  <div class="fw-bold text-primary"><%= test.questionCount %></div>
                  <small class="text-muted">Questions</small>
                </div>
              </div>
              <div class="col-6">
                <div class="bg-light rounded-2 p-2 text-center">
                  <div class="fw-bold text-purple"><%= test.resultCount %></div>
                  <small class="text-muted">Attempts</small>
                </div>
              </div>
              <div class="col-6">
                <div class="bg-light rounded-2 p-2 text-center">
                  <div class="fw-bold"><%= test.duration %> min</div>
                  <small class="text-muted">Duration</small>
                </div>
              </div>
              <div class="col-6">
                <div class="bg-light rounded-2 p-2 text-center">
                  <div class="fw-bold"><%= test.totalMarks %></div>
                  <small class="text-muted">Total Marks</small>
                </div>
              </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
              <a href="/admin/tests/<%= test._id %>/questions" class="btn btn-sm btn-primary">
                <i class="bi bi-question-circle me-1"></i>Questions
              </a>
              <a href="/admin/tests/<%= test._id %>/edit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-pencil me-1"></i>Edit
              </a>
              <a href="/admin/results?testId=<%= test._id %>" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-bar-chart me-1"></i>Results
              </a>
              <a href="/admin/tests/<%= test._id %>/toggle"
                 class="btn btn-sm <%= test.isActive ? 'btn-outline-warning' : 'btn-outline-success' %>"
                 onclick="return confirm('Toggle test status?')">
                <i class="bi bi-<%= test.isActive ? 'pause' : 'play' %>-circle me-1"></i>
                <%= test.isActive ? 'Deactivate' : 'Activate' %>
              </a>
              <form action="/admin/tests/<%= test._id %>/delete" method="POST" class="d-inline"
                    onsubmit="return confirm('DELETE this test and ALL related data? This cannot be undone!')">
                <button class="btn btn-sm btn-outline-danger" type="submit">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          </div>
          <div class="card-footer bg-transparent text-muted small">
            Created <%= new Date(test.createdAt).toLocaleDateString('en-IN') %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
