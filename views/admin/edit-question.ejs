<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'tests' }) %>

<div class="page-header">
  <div class="container">
    <h1><i class="bi bi-pencil me-2"></i>Edit Question</h1>
    <p>Test: <strong><%= test.title %></strong> &nbsp;·&nbsp; Code: <span class="code-badge"><%= test.code %></span></p>
  </div>
</div>

<main class="container pb-5" style="max-width:720px;">
  <%- include('../partials/flash') %>

  <div class="card">
    <div class="card-header">
      <span class="section-title"><i class="bi bi-question-circle me-2"></i>Question Details</span>
    </div>
    <div class="card-body p-4">
      <form action="/admin/questions/<%= question._id %>/edit" method="POST" id="editQForm">

        <div class="mb-3">
          <label class="form-label">Question <span class="text-danger">*</span></label>
          <textarea name="question" class="form-control" rows="3" required><%= question.question %></textarea>
        </div>

        <div class="row g-3 mb-3">
          <% ['A','B','C','D'].forEach((letter, i) => { %>
          <div class="col-12 col-md-6">
            <label class="form-label">Option <%= letter %> <span class="text-danger">*</span></label>
            <input type="text" name="opt<%= letter %>" class="form-control"
                   value="<%= question.options[i] %>" required>
          </div>
          <% }) %>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-12 col-md-6">
            <label class="form-label">Correct Answer <span class="text-danger">*</span></label>
            <select name="correctAnswer" class="form-select" required>
              <% ['A','B','C','D'].forEach((letter, i) => { %>
              <option value="<%= i %>" <%= question.correctAnswer === i ? 'selected' : '' %>>
                Option <%= letter %>
              </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label">Marks</label>
            <input type="number" name="marks" class="form-control"
                   value="<%= question.marks %>" min="1" max="10">
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label">Explanation (optional)</label>
          <textarea name="explanation" class="form-control" rows="2"><%= question.explanation || '' %></textarea>
          <div class="form-text">Shown to students after they submit the test.</div>
        </div>

        <hr class="my-3">

        <div class="d-flex gap-2 justify-content-end">
          <a href="/admin/tests/<%= test._id %>/questions" class="btn btn-outline-secondary">Cancel</a>
          <button type="submit" class="btn btn-primary px-4" id="submitBtn">
            <i class="bi bi-save me-1"></i>Save Question
          </button>
        </div>

      </form>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.getElementById('editQForm').addEventListener('submit', function () {
    const btn = document.getElementById('submitBtn');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
    btn.disabled = true;
  });
</script>
</body>
</html>
