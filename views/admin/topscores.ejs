<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'results' }) %>

<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1><i class="bi bi-trophy me-2"></i>Top Scores & Analytics</h1>
        <p>Leaderboard and test-wise performance summary.</p>
      </div>
      <a href="/admin/results" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Back to Results
      </a>
    </div>
  </div>
</div>

<main class="container pb-5">
  <%- include('../partials/flash') %>

  <!-- Filter -->
  <div class="card mb-4">
    <div class="card-body">
      <form method="GET" action="/admin/results/topscores" class="d-flex gap-2 flex-wrap align-items-end">
        <div>
          <label class="form-label mb-1">Filter by Test</label>
          <select name="testId" class="form-select">
            <option value="">All Tests</option>
            <% tests.forEach(t => { %>
              <option value="<%= t._id %>" <%= selectedTest === t._id.toString() ? 'selected' : '' %>>
                <%= t.title %>
              </option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="btn btn-primary mt-3">Apply</button>
        <% if (selectedTest) { %>
          <a href="/admin/results/topscores" class="btn btn-outline-secondary mt-3">Clear</a>
        <% } %>
      </form>
    </div>
  </div>

  <!-- Test-wise Stats Cards -->
  <% if (testStats.length > 0) { %>
  <h5 class="fw-bold mb-3"><i class="bi bi-bar-chart me-2"></i>Test-wise Summary</h5>
  <div class="row g-3 mb-4">
    <% testStats.forEach(t => { %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
              <div class="fw-bold"><%= t.testTitle %></div>
              <span class="badge bg-primary bg-opacity-10 text-primary small"><%= t.testDomain %></span>
            </div>
            <span class="badge bg-secondary"><%= t.totalAttempts %> attempts</span>
          </div>
          <div class="row g-2 mt-2 text-center">
            <div class="col-4">
              <div class="fw-bold text-success fs-5"><%= t.highestScore.toFixed(1) %>%</div>
              <div class="text-muted" style="font-size:0.72rem;">Highest</div>
            </div>
            <div class="col-4">
              <div class="fw-bold text-primary fs-5"><%= t.avgScore.toFixed(1) %>%</div>
              <div class="text-muted" style="font-size:0.72rem;">Average</div>
            </div>
            <div class="col-4">
              <div class="fw-bold text-danger fs-5"><%= t.lowestScore.toFixed(1) %>%</div>
              <div class="text-muted" style="font-size:0.72rem;">Lowest</div>
            </div>
          </div>
          <div class="mt-3">
            <div class="d-flex justify-content-between small text-muted mb-1">
              <span>Pass Rate</span>
              <span><%= t.passCount %>/<%= t.totalAttempts %> (<%= ((t.passCount/t.totalAttempts)*100).toFixed(0) %>%)</span>
            </div>
            <div class="progress" style="height:6px;">
              <div class="progress-bar bg-success" style="width:<%= ((t.passCount/t.totalAttempts)*100).toFixed(0) %>%"></div>
            </div>
          </div>
          <!-- Download this test -->
          <a href="/admin/results/download?testId=<%= t._id %>"
             class="btn btn-sm btn-outline-success w-100 mt-3">
            <i class="bi bi-download me-1"></i>Download Excel
          </a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- Top 20 Leaderboard -->
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span class="section-title"><i class="bi bi-trophy me-2"></i>Top 20 Leaderboard</span>
      <a href="/admin/results/download<%= selectedTest ? '?testId=' + selectedTest : '' %>"
         class="btn btn-sm btn-success">
        <i class="bi bi-file-earmark-excel me-1"></i>Download All Excel
      </a>
    </div>
    <div class="card-body p-0">
      <% if (topResults.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-trophy"></i>
          <p>No results yet.</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>Rank</th>
                <th>Student</th>
                <th>Test</th>
                <th>Score</th>
                <th>%</th>
                <th>Status</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% topResults.forEach((r, i) => { %>
              <tr class="<%= i === 0 ? 'table-warning' : i === 1 ? 'table-light' : i === 2 ? 'table-light' : '' %>">
                <td class="fw-bold text-center" style="width:60px;">
                  <% if (i === 0) { %><span class="fs-5">🥇</span>
                  <% } else if (i === 1) { %><span class="fs-5">🥈</span>
                  <% } else if (i === 2) { %><span class="fs-5">🥉</span>
                  <% } else { %><span class="text-muted">#<%= i+1 %></span>
                  <% } %>
                </td>
                <td>
                  <div class="fw-semibold small"><%= r.studentName || '—' %></div>
                  <div class="text-muted" style="font-size:0.75rem;"><%= r.studentEmail %></div>
                </td>
                <td>
                  <div class="small fw-semibold"><%= r.testTitle %></div>
                  <span class="badge bg-light text-dark border" style="font-size:0.7rem;"><%= r.testDomain %></span>
                </td>
                <td class="fw-bold"><%= r.score %>/<%= r.totalMarks %></td>
                <td>
                  <span class="fw-bold <%= r.percentage >= 80 ? 'text-success' : r.percentage >= 50 ? 'text-primary' : 'text-danger' %>">
                    <%= r.percentage.toFixed(1) %>%
                  </span>
                  <div class="progress mt-1" style="height:4px;width:60px;">
                    <div class="progress-bar" style="width:<%= r.percentage %>%"></div>
                  </div>
                </td>
                <td>
                  <% if (r.isPassed) { %>
                    <span class="badge bg-success">Passed</span>
                  <% } else { %>
                    <span class="badge bg-danger">Failed</span>
                  <% } %>
                </td>
                <td class="text-muted small">
                  <%= new Date(r.submittedAt).toLocaleDateString('en-IN') %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
