<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'tests' }) %>

<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1><i class="bi bi-question-circle me-2"></i>Add Questions</h1>
        <p>
          Test: <strong><%= test.title %></strong> &nbsp;|&nbsp;
          Code: <span class="code-badge"><%= test.code %></span> &nbsp;|&nbsp;
          <%= questions.length %> question(s) added
        </p>
      </div>
      <a href="/admin/tests" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Back to Tests
      </a>
    </div>
  </div>
</div>

<main class="container pb-5">
  <%- include('../partials/flash') %>

  <div class="row g-4">

    <!-- ── Add Question Form ─────────────────────────── -->
    <div class="col-12 col-lg-5">
      <div class="card sticky-top" style="top:80px;">
        <div class="card-header">
          <span class="section-title"><i class="bi bi-plus-square me-2"></i>Add New Question</span>
        </div>
        <div class="card-body p-3">
          <form action="/admin/tests/<%= test._id %>/questions" method="POST" id="addQForm">

            <div class="mb-3">
              <label class="form-label">Question Text <span class="text-danger">*</span></label>
              <textarea name="question" class="form-control" rows="3"
                        placeholder="Enter the question here..." required></textarea>
            </div>

            <div class="mb-2">
              <label class="form-label fw-semibold">Options <span class="text-danger">*</span></label>
              <div class="d-flex flex-column gap-2">
                <div class="input-group">
                  <span class="input-group-text fw-bold bg-primary text-white border-0" style="width:38px;">A</span>
                  <input type="text" name="optA" class="form-control" placeholder="Option A" required>
                </div>
                <div class="input-group">
                  <span class="input-group-text fw-bold bg-primary text-white border-0" style="width:38px;">B</span>
                  <input type="text" name="optB" class="form-control" placeholder="Option B" required>
                </div>
                <div class="input-group">
                  <span class="input-group-text fw-bold bg-primary text-white border-0" style="width:38px;">C</span>
                  <input type="text" name="optC" class="form-control" placeholder="Option C" required>
                </div>
                <div class="input-group">
                  <span class="input-group-text fw-bold bg-primary text-white border-0" style="width:38px;">D</span>
                  <input type="text" name="optD" class="form-control" placeholder="Option D" required>
                </div>
              </div>
            </div>

            <div class="row g-2 mt-1">
              <div class="col-7">
                <label class="form-label">Correct Answer <span class="text-danger">*</span></label>
                <select name="correctAnswer" class="form-select" required>
                  <option value="" disabled selected>Select correct...</option>
                  <option value="0">A — Option A</option>
                  <option value="1">B — Option B</option>
                  <option value="2">C — Option C</option>
                  <option value="3">D — Option D</option>
                </select>
              </div>
              <div class="col-5">
                <label class="form-label">Marks</label>
                <input type="number" name="marks" class="form-control" value="1" min="1" max="10">
              </div>
            </div>

            <div class="mt-2">
              <label class="form-label">Explanation (optional)</label>
              <input type="text" name="explanation" class="form-control"
                     placeholder="Brief explanation of correct answer">
            </div>

            <hr>
            <button type="submit" class="btn btn-primary w-100" id="addQBtn">
              <i class="bi bi-plus-circle me-1"></i>Add Question
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- ── Questions List ─────────────────────────────── -->
    <div class="col-12 col-lg-7">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span class="section-title">
            <i class="bi bi-list-ol me-2"></i>
            Questions (<%= questions.length %>)
          </span>
          <% if (test.questionLimit > 0) { %>
          <span class="badge bg-info text-dark">
            Limit: <%= test.questionLimit %> per student
          </span>
          <% } %>
        </div>
        <div class="card-body p-0">
          <% if (questions.length === 0) { %>
            <div class="empty-state">
              <i class="bi bi-question-circle"></i>
              <p>No questions yet. Use the form to add the first question.</p>
            </div>
          <% } else { %>
            <div class="p-3 d-flex flex-column gap-3">
              <% questions.forEach((q, idx) => { %>
              <div class="border rounded-2 p-3 position-relative">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <span class="question-number">Q<%= idx + 1 %></span>
                  <div class="d-flex gap-1">
                    <a href="/admin/questions/<%= q._id %>/edit" class="btn btn-sm btn-outline-secondary" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <form action="/admin/questions/<%= q._id %>/delete" method="POST"
                          onsubmit="return confirm('Delete this question?')">
                      <button class="btn btn-sm btn-outline-danger" type="submit" title="Delete">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </div>
                <p class="question-text mb-2"><%= q.question %></p>
                <div class="d-flex flex-column gap-1">
                  <% q.options.forEach((opt, oIdx) => { %>
                  <div class="d-flex align-items-center gap-2 rounded px-2 py-1
                       <%= oIdx === q.correctAnswer ? 'bg-success bg-opacity-10 border border-success border-opacity-25' : 'bg-light' %>">
                    <span class="badge <%= oIdx === q.correctAnswer ? 'bg-success' : 'bg-secondary' %>"
                          style="width:22px;height:22px;display:flex;align-items:center;justify-content:center;">
                      <%= ['A','B','C','D'][oIdx] %>
                    </span>
                    <span style="font-size:0.85rem;"><%= opt %></span>
                    <% if (oIdx === q.correctAnswer) { %>
                      <i class="bi bi-check-circle-fill text-success ms-auto"></i>
                    <% } %>
                  </div>
                  <% }) %>
                </div>
                <% if (q.explanation) { %>
                <div class="mt-2 text-muted small">
                  <i class="bi bi-lightbulb me-1 text-warning"></i><%= q.explanation %>
                </div>
                <% } %>
                <div class="text-end mt-1">
                  <span class="badge bg-primary bg-opacity-10 text-primary"><%= q.marks %> mark(s)</span>
                </div>
              </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.getElementById('addQForm').addEventListener('submit', function () {
    const btn = document.getElementById('addQBtn');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Adding...';
    btn.disabled = true;
  });
</script>
</body>
</html>
