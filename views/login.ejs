<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <%- include('partials/pwa-head') %>
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body class="p-0 m-0">

<div class="login-wrapper">
  <div class="login-card fade-in">

    <!-- Logo -->
    <div class="login-logo">A</div>
    <div class="login-title">APARAITECH</div>
    <div class="login-subtitle">Online Test Portal — Secure Assessment Platform</div>

    <!-- Flash Messages -->
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 px-3 small" role="alert">
        <i class="bi bi-check-circle-fill me-1"></i> <%- success_msg %>
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 px-3 small" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i> <%= error_msg %>
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Tabs -->
    <ul class="nav auth-tabs border-bottom mb-4" id="loginTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="student-tab" data-bs-toggle="tab"
                data-bs-target="#student-login" type="button" role="tab">
          <i class="bi bi-mortarboard me-1"></i>Login
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="register-tab" data-bs-toggle="tab"
                data-bs-target="#student-register" type="button" role="tab">
          <i class="bi bi-person-plus me-1"></i>Register
        </button>
      </li>

    </ul>

    <div class="tab-content" id="loginTabsContent">

      <!--  STUDENT LOGIN  -->
      <div class="tab-pane fade show active" id="student-login" role="tabpanel">
        <form action="/login/student" method="POST">
          <div class="mb-3">
            <label class="form-label">Email Address</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-envelope text-muted"></i>
              </span>
              <input type="email" class="form-control border-start-0 ps-0"
                     name="email" placeholder="you@example.com" required autocomplete="email">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-key text-muted"></i>
              </span>
              <input type="password" class="form-control border-start-0 ps-0"
                     name="password" placeholder="••••••••" required id="studentPass">
              <button class="btn btn-outline-secondary" type="button" onclick="togglePass('studentPass', 'eye1')">
                <i class="bi bi-eye" id="eye1"></i>
              </button>
            </div>
          </div>
          <button type="submit" class="btn btn-primary w-100 py-2">
            <i class="bi bi-box-arrow-in-right me-1"></i>Login
          </button>
        </form>
        <p class="text-center mt-3 small text-muted">
          Don't have an account?
          <a href="#" onclick="switchTab('register-tab')" class="text-primary">Register here</a>
        </p>
      </div>

      <!--  STUDENT REGISTER  -->
      <div class="tab-pane fade" id="student-register" role="tabpanel">
        <form action="/login/register" method="POST">
          <div class="mb-3">
            <label class="form-label">Full Name</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-person text-muted"></i>
              </span>
              <input type="text" class="form-control border-start-0 ps-0"
                     name="name" placeholder="Your full name" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">College Name</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-building text-muted"></i>
              </span>
              <% if (colleges && colleges.length > 0) { %>
                <select class="form-select border-start-0" name="collegeName" required>
                  <option value="">-- Select your college --</option>
                  <% colleges.forEach(c => { %>
                    <option value="<%= c.name %>"><%= c.name %></option>
                  <% }) %>
                </select>
              <% } else { %>
                <input type="text" class="form-control border-start-0 ps-0"
                       name="collegeName" placeholder="Enter your college name" required>
              <% } %>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Email Address</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-envelope text-muted"></i>
              </span>
              <input type="email" class="form-control border-start-0 ps-0"
                     name="email" placeholder="you@example.com" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Mobile Number</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-phone text-muted"></i>
              </span>
              <input type="tel" class="form-control border-start-0 ps-0"
                     name="mobile" placeholder="10-digit mobile number"
                     pattern="[6-9][0-9]{9}" maxlength="10" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-key text-muted"></i>
              </span>
              <input type="password" class="form-control border-start-0 ps-0"
                     name="password" placeholder="Min 6 characters" required id="regPass">
              <button class="btn btn-outline-secondary" type="button" onclick="togglePass('regPass', 'eye2')">
                <i class="bi bi-eye" id="eye2"></i>
              </button>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Confirm Password</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-key-fill text-muted"></i>
              </span>
              <input type="password" class="form-control border-start-0 ps-0"
                     name="confirmPassword" placeholder="Re-enter password" required id="regPass2">
              <button class="btn btn-outline-secondary" type="button" onclick="togglePass('regPass2', 'eye3')">
                <i class="bi bi-eye" id="eye3"></i>
              </button>
            </div>
          </div>
          <button type="submit" class="btn btn-success w-100 py-2">
            <i class="bi bi-person-check me-1"></i>Register
          </button>
        </form>
        <p class="text-center mt-3 small text-muted">
          Already registered?
          <a href="#" onclick="switchTab('student-tab')" class="text-primary">Login here</a>
        </p>
      </div>



    </div><!-- /tab-content -->

    <!-- Footer -->
    <div class="text-center mt-4 pt-3 border-top" style="font-size:0.73rem; color:#aaa;">
      <strong>APARAITECH</strong> · Reg No: 2431000320445474 <br>
      Baramati, Maharashtra 413102 · info@aparaitechsoftware.org
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function togglePass(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon  = document.getElementById(iconId);
    if (input.type === 'password') {
      input.type = 'text';
      icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
      input.type = 'password';
      icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
  }

  function switchTab(tabId) {
    const tab = new bootstrap.Tab(document.getElementById(tabId));
    tab.show();
  }


</script>
</body>
</html>
