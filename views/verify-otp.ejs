<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body class="p-0 m-0">

<div class="login-wrapper">
  <div class="login-card fade-in" style="max-width:420px;">

    <div class="login-logo" style="background:linear-gradient(135deg,#2e7d32,#66bb6a);">
      <i class="bi bi-shield-lock-fill" style="font-size:1.5rem;"></i>
    </div>
    <div class="login-title">Verify OTP</div>
    <div class="login-subtitle">Enter the 6-digit code sent to <strong><%= email %></strong></div>

    <!-- Flash -->
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success border-0 rounded-3 py-2 px-3 small">
        <i class="bi bi-check-circle-fill me-1"></i> <%- success_msg %>
      </div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="alert alert-danger border-0 rounded-3 py-2 px-3 small">
        <i class="bi bi-exclamation-triangle-fill me-1"></i> <%= error_msg %>
      </div>
    <% } %>

    <form action="/login/verify-otp" method="POST" id="verifyForm">
      <div class="mb-4">
        <label class="form-label text-center w-100 fw-semibold mb-3">Enter OTP Code</label>
        <!-- OTP digit boxes -->
        <div class="d-flex justify-content-center gap-2 mb-2" id="otp-boxes">
          <% for(let i = 0; i < 6; i++) { %>
          <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]"
                 class="otp-box form-control text-center fw-bold fs-4 p-0"
                 style="width:48px;height:56px;border-radius:10px;border:2px solid #e0e0e0;"
                 data-index="<%= i %>" autocomplete="off">
          <% } %>
        </div>
        <!-- Hidden full OTP input -->
        <input type="hidden" name="otp" id="fullOtp">
      </div>

      <button type="submit" class="btn btn-success w-100 py-2" id="verifyBtn" disabled>
        <i class="bi bi-check-circle me-1"></i>Verify & Login
      </button>
    </form>

    <div class="text-center mt-3">
      <p class="text-muted small mb-1">Didn't receive the code?</p>
      <a href="/login" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-clockwise me-1"></i>Resend OTP
      </a>
    </div>

    <!-- Countdown timer -->
    <div class="text-center mt-3">
      <span class="badge bg-warning text-dark" id="otpTimer">
        <i class="bi bi-clock me-1"></i>Expires in <span id="countdown">10:00</span>
      </span>
    </div>

    <div class="text-center mt-4 pt-3 border-top" style="font-size:0.73rem;color:#aaa;">
      <strong>APARAITECH</strong> · info@aparaitechsoftware.org
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const boxes   = document.querySelectorAll('.otp-box');
  const fullOtp = document.getElementById('fullOtp');
  const verifyBtn = document.getElementById('verifyBtn');

  // Auto-advance between digit boxes
  boxes.forEach((box, idx) => {
    box.addEventListener('input', (e) => {
      box.value = box.value.replace(/\D/g, '').slice(-1);
      if (box.value && idx < boxes.length - 1) boxes[idx + 1].focus();
      updateFullOtp();
    });
    box.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace' && !box.value && idx > 0) boxes[idx - 1].focus();
    });
    box.addEventListener('paste', (e) => {
      e.preventDefault();
      const pasted = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '');
      boxes.forEach((b, i) => { b.value = pasted[i] || ''; });
      updateFullOtp();
      if (pasted.length >= 6) boxes[5].focus();
    });
  });

  function updateFullOtp() {
    const otp = [...boxes].map(b => b.value).join('');
    fullOtp.value = otp;
    verifyBtn.disabled = otp.length !== 6;
    boxes.forEach(b => {
      b.style.borderColor = b.value ? '#0d47a1' : '#e0e0e0';
    });
  }

  // Form submit spinner
  document.getElementById('verifyForm').addEventListener('submit', () => {
    verifyBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Verifying...';
    verifyBtn.disabled = true;
  });

  // OTP Countdown timer (10 minutes)
  let timeLeft = 10 * 60;
  const cdEl = document.getElementById('countdown');
  const timerBadge = document.getElementById('otpTimer');
  const interval = setInterval(() => {
    if (timeLeft <= 0) {
      clearInterval(interval);
      cdEl.textContent = 'Expired!';
      timerBadge.classList.replace('bg-warning', 'bg-danger');
      timerBadge.classList.replace('text-dark', 'text-white');
      return;
    }
    timeLeft--;
    const m = Math.floor(timeLeft / 60).toString().padStart(2, '0');
    const s = (timeLeft % 60).toString().padStart(2, '0');
    cdEl.textContent = `${m}:${s}`;
    if (timeLeft <= 60) {
      timerBadge.classList.replace('bg-warning', 'bg-danger');
      timerBadge.classList.replace('text-dark', 'text-white');
    }
  }, 1000);

  // Auto-focus first box
  boxes[0].focus();
</script>
</body>
</html>
