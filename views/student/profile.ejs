<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <%- include('../partials/pwa-head') %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
  <style>
    .profile-hero {
      background: linear-gradient(135deg, var(--primary-dark, #0d47a1), var(--primary-light, #1976d2));
      color: #fff;
      padding: 2.5rem 0 3.5rem;
    }
    .avatar-ring {
      width: 90px; height: 90px; border-radius: 50%;
      background: rgba(255,255,255,0.2);
      border: 3px solid rgba(255,255,255,0.5);
      display: flex; align-items: center; justify-content: center;
      font-size: 2.2rem; font-weight: 800; color: #fff;
      margin: 0 auto 1rem;
    }
    .profile-tabs-wrap {
      background: #fff;
      border-bottom: 1px solid #e0e0e0;
      position: sticky; top: 56px; z-index: 100;
    }
    .profile-tabs .nav-link {
      color: #666; border-radius: 0; border-bottom: 3px solid transparent;
      padding: 0.75rem 1.2rem; font-size: 0.88rem; font-weight: 500;
    }
    .profile-tabs .nav-link.active {
      color: var(--primary, #1565c0); border-bottom-color: var(--primary, #1565c0);
      background: transparent;
    }
    .profile-tabs .nav-link i { font-size: 0.95rem; }
    .stat-pill {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(255,255,255,0.15); border-radius: 20px;
      padding: 5px 14px; font-size: 0.82rem;
    }
    .stat-pill strong { font-size: 1.1rem; }
    .perf-bar-wrap { height: 6px; background: rgba(255,255,255,0.2); border-radius: 3px; overflow: hidden; }
    .perf-bar      { height: 100%; border-radius: 3px; transition: width 1s ease; }
    .ws-card { border-left: 4px solid transparent; }
    .ws-card.active-ws { border-left-color: #198754; }
    .ws-card.ended-ws  { border-left-color: #6c757d; }
    .att-ring-wrap { position: relative; width: 52px; height: 52px; flex-shrink: 0; }
    .att-ring-wrap svg { transform: rotate(-90deg); }
    .att-ring-val {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem; font-weight: 700; color: var(--bs-body-color);
    }
    .edit-card { max-width: 520px; }
  </style>
</head>
<body>
<%- include('../partials/header', { activePage: 'profile' }) %>

<!-- ═══════════════════ HERO ═══════════════════ -->
<div class="profile-hero">
  <div class="container text-center">
    <div class="avatar-ring"><%= (user.name || user.email).charAt(0).toUpperCase() %></div>
    <h2 class="fw-bold mb-1"><%= user.name || 'Student' %></h2>
    <p class="opacity-75 mb-3 small"><%= user.email %> · <%= user.collegeName || 'No college' %></p>
    <div class="d-flex justify-content-center flex-wrap gap-2">
      <% if (testStats.total > 0) { %>
      <div class="stat-pill"><strong><%= testStats.total %></strong> tests taken</div>
      <div class="stat-pill"><strong><%= testStats.passed %></strong> passed</div>
      <% if (testStats.avgPct) { %>
      <div class="stat-pill"><strong><%= testStats.avgPct %>%</strong> avg score</div>
      <% } %>
      <% } %>
      <div class="stat-pill"><strong><%= enrollments.length %></strong> workshops</div>
    </div>

    <% if (testStats.total > 0) { %>
    <div class="mt-3 mx-auto" style="max-width:320px;">
      <div class="d-flex justify-content-between small opacity-75 mb-1">
        <span>Pass rate</span>
        <span><%= testStats.passed %>/<%= testStats.total %></span>
      </div>
      <div class="perf-bar-wrap">
        <div class="perf-bar" style="width:<%= Math.round(testStats.passed/testStats.total*100) %>%; background:#81c784;"></div>
      </div>
    </div>
    <% } %>
  </div>
</div>

<!-- ═══════════════════ TABS ═══════════════════ -->
<div class="profile-tabs-wrap shadow-sm">
  <div class="container">
    <ul class="nav profile-tabs" id="profileTabs" role="tablist">
      <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-overview" type="button">
          <i class="bi bi-grid me-1"></i>Overview
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-tests" type="button">
          <i class="bi bi-journal-check me-1"></i>Tests
          <% if (testStats.total > 0) { %><span class="badge bg-primary bg-opacity-10 text-primary ms-1 small"><%= testStats.total %></span><% } %>
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-workshops" type="button">
          <i class="bi bi-mortarboard me-1"></i>Workshops
          <% if (enrollments.length > 0) { %><span class="badge bg-success bg-opacity-10 text-success ms-1 small"><%= enrollments.length %></span><% } %>
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-edit" type="button">
          <i class="bi bi-pencil me-1"></i>Edit Profile
        </button>
      </li>
    </ul>
  </div>
</div>

<main class="container pb-5 mt-4">
  <%- include('../partials/flash') %>
  <div class="tab-content">

    <!-- ═══════ OVERVIEW TAB ═══════ -->
    <div class="tab-pane fade show active" id="tab-overview">
      <div class="row g-4">

        <!-- Test performance summary -->
        <div class="col-12 col-md-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-header"><span class="section-title"><i class="bi bi-bar-chart me-2"></i>Test Performance</span></div>
            <div class="card-body">
              <% if (testStats.total === 0) { %>
                <div class="text-center text-muted py-3">
                  <i class="bi bi-journal-x fs-2 d-block mb-2"></i>No tests taken yet
                  <a href="/student/enter-code" class="btn btn-sm btn-primary mt-2">Take a Test</a>
                </div>
              <% } else { %>
              <div class="row g-3 text-center">
                <div class="col-6">
                  <div class="p-3 rounded-3 bg-success bg-opacity-10">
                    <div class="fw-bold fs-3 text-success"><%= testStats.passed %></div>
                    <div class="text-muted small">Passed</div>
                  </div>
                </div>
                <div class="col-6">
                  <div class="p-3 rounded-3 bg-danger bg-opacity-10">
                    <div class="fw-bold fs-3 text-danger"><%= testStats.failed %></div>
                    <div class="text-muted small">Failed</div>
                  </div>
                </div>
                <div class="col-6">
                  <div class="p-3 rounded-3 bg-primary bg-opacity-10">
                    <div class="fw-bold fs-3 text-primary"><%= testStats.avgPct %>%</div>
                    <div class="text-muted small">Avg Score</div>
                  </div>
                </div>
                <div class="col-6">
                  <div class="p-3 rounded-3 bg-warning bg-opacity-10">
                    <div class="fw-bold fs-3 text-warning"><%= testStats.bestPct %>%</div>
                    <div class="text-muted small">Best Score</div>
                  </div>
                </div>
              </div>
              <!-- Recent tests (last 3) -->
              <% if (results.length > 0) { %>
              <hr class="my-3">
              <p class="text-muted small mb-2 fw-semibold">Recent tests</p>
              <% results.slice(0, 3).forEach(r => { %>
              <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge <%= r.isPassed ? 'bg-success' : 'bg-danger' %>" style="width:16px;height:16px;padding:0;border-radius:50%;display:inline-block;"></span>
                <div class="flex-grow-1 text-truncate small fw-semibold"><%= r.testTitle %></div>
                <div class="text-muted small ms-auto flex-shrink-0"><%= r.percentage.toFixed(0) %>%</div>
              </div>
              <% }) %>
              <% } %>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Workshop summary -->
        <div class="col-12 col-md-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-header"><span class="section-title"><i class="bi bi-mortarboard me-2"></i>Workshop Activity</span></div>
            <div class="card-body">
              <% if (enrollments.length === 0) { %>
                <div class="text-center text-muted py-3">
                  <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>No workshops enrolled yet
                  <a href="/student/workshops" class="btn btn-sm btn-success mt-2">Browse Workshops</a>
                </div>
              <% } else { %>
              <% enrollments.slice(0, 4).forEach(e => { %>
              <% const w = e.workshop; %>
              <% if (!w) { return; } %>
              <div class="d-flex align-items-start gap-3 mb-3 pb-3 border-bottom">
                <% if (e.totalSessions > 0 && e.attendancePct !== null) { %>
                <div class="att-ring-wrap">
                  <svg width="52" height="52" viewBox="0 0 52 52">
                    <circle cx="26" cy="26" r="21" fill="none" stroke="#e0e0e0" stroke-width="4"/>
                    <circle cx="26" cy="26" r="21" fill="none"
                      stroke="<%= e.attendancePct >= 75 ? '#198754' : e.attendancePct >= 50 ? '#ffc107' : '#dc3545' %>"
                      stroke-width="4" stroke-linecap="round"
                      stroke-dasharray="<%= Math.round(2*Math.PI*21) %>"
                      stroke-dashoffset="<%= Math.round(2*Math.PI*21*(1-e.attendancePct/100)) %>"/>
                  </svg>
                  <div class="att-ring-val"><%= e.attendancePct %>%</div>
                </div>
                <% } else { %>
                <div style="width:52px;height:52px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
                  <i class="bi bi-mortarboard-fill text-success fs-4"></i>
                </div>
                <% } %>
                <div class="flex-grow-1 min-w-0">
                  <div class="fw-semibold text-truncate small"><%= w.title %></div>
                  <div class="text-muted" style="font-size:0.75rem;">
                    <%= new Date(w.startDate).toLocaleDateString('en-IN') %>
                    <% if (e.totalSessions > 0) { %> · <%= e.markedSessions %>/<%= e.totalSessions %> sessions<% } %>
                    <% if (e.totalTasks > 0) { %> · <%= e.doneTasksCount %>/<%= e.totalTasks %> tasks<% } %>
                  </div>
                  <span class="badge <%= e.paymentStatus === 'free' ? 'bg-info' : 'bg-success' %> bg-opacity-10 <%= e.paymentStatus === 'free' ? 'text-info' : 'text-success' %> mt-1" style="font-size:0.7rem;">
                    <%= e.paymentStatus === 'free' ? 'Free' : '₹' + e.fee + ' paid' %>
                  </span>
                </div>
              </div>
              <% }) %>
              <% if (enrollments.length > 4) { %>
              <div class="text-center mt-1">
                <button class="btn btn-sm btn-link text-muted" onclick="document.querySelector('[data-bs-target=\'#tab-workshops\']').click()">
                  + <%= enrollments.length - 4 %> more workshops
                </button>
              </div>
              <% } %>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Account info -->
        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-header"><span class="section-title"><i class="bi bi-person-badge me-2"></i>Account Details</span></div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-6 col-md-3">
                  <div class="text-muted small">Full Name</div>
                  <div class="fw-semibold"><%= user.name || '—' %></div>
                </div>
                <div class="col-6 col-md-3">
                  <div class="text-muted small">Email</div>
                  <div class="fw-semibold text-truncate"><%= user.email %></div>
                </div>
                <div class="col-6 col-md-3">
                  <div class="text-muted small">Mobile</div>
                  <div class="fw-semibold"><%= user.mobile || '—' %></div>
                </div>
                <div class="col-6 col-md-3">
                  <div class="text-muted small">College</div>
                  <div class="fw-semibold"><%= user.collegeName || '—' %></div>
                </div>
                <div class="col-6 col-md-3">
                  <div class="text-muted small">Account Type</div>
                  <div><span class="badge bg-primary">Student</span></div>
                </div>
                <div class="col-6 col-md-3">
                  <div class="text-muted small">Member Since</div>
                  <div class="fw-semibold"><%= new Date(user.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'}) %></div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════ TESTS TAB ═══════ -->
    <div class="tab-pane fade" id="tab-tests">
      <% if (results.length === 0) { %>
        <div class="card border-0 shadow-sm">
          <div class="empty-state">
            <i class="bi bi-journal-x"></i>
            <p>No tests taken yet.</p>
            <a href="/student/enter-code" class="btn btn-primary">Take a Test</a>
          </div>
        </div>
      <% } else { %>
      <div class="card border-0 shadow-sm">
        <div class="card-header d-flex align-items-center justify-content-between">
          <span class="section-title"><i class="bi bi-clock-history me-2"></i>Test History (<%= results.length %>)</span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table mb-0">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Test</th>
                  <th>Score</th>
                  <th>Status</th>
                  <th>Time</th>
                  <th>Date</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% results.forEach((r, idx) => { %>
                <tr>
                  <td class="text-muted small"><%= idx + 1 %></td>
                  <td>
                    <div class="fw-semibold"><%= r.testTitle %></div>
                    <span class="badge bg-primary bg-opacity-10 text-primary small"><%= r.testDomain %></span>
                  </td>
                  <td>
                    <div class="fw-bold"><%= r.score %>/<%= r.totalMarks %></div>
                    <div class="progress mt-1" style="height:4px;width:80px;">
                      <div class="progress-bar <%= r.isPassed ? 'bg-success' : 'bg-danger' %>" style="width:<%= r.percentage %>%"></div>
                    </div>
                    <small class="text-muted"><%= r.percentage.toFixed(1) %>%</small>
                  </td>
                  <td>
                    <% if (r.isPassed) { %>
                      <span class="badge bg-success"><i class="bi bi-check me-1"></i>Passed</span>
                    <% } else { %>
                      <span class="badge bg-danger"><i class="bi bi-x me-1"></i>Failed</span>
                    <% } %>
                  </td>
                  <td class="text-muted small">
                    <% if (r.timeTaken > 0) { %>
                      <%= Math.floor(r.timeTaken/60) %>m <%= r.timeTaken%60 %>s
                    <% } else { %> — <% } %>
                  </td>
                  <td class="text-muted small"><%= new Date(r.submittedAt).toLocaleDateString('en-IN') %></td>
                  <td>
                    <a href="/student/results/<%= r._id %>" class="btn btn-sm btn-outline-primary">
                      <i class="bi bi-eye me-1"></i>View
                    </a>
                    <a href="/student/results/<%= r._id %>/pdf" class="btn btn-sm btn-outline-danger ms-1">
                      <i class="bi bi-file-pdf"></i>
                    </a>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <!-- ═══════ WORKSHOPS TAB ═══════ -->
    <div class="tab-pane fade" id="tab-workshops">
      <% if (enrollments.length === 0) { %>
        <div class="card border-0 shadow-sm">
          <div class="empty-state">
            <i class="bi bi-mortarboard"></i>
            <p>You haven't enrolled in any workshops yet.</p>
            <a href="/student/workshops" class="btn btn-success">Browse Workshops</a>
          </div>
        </div>
      <% } else { %>
      <div class="row g-3">
        <% enrollments.forEach(e => { %>
        <% const w = e.workshop; if (!w) return; %>
        <% const isActive = w.isActive && new Date(w.endDate) >= new Date(); %>
        <div class="col-12 col-md-6">
          <div class="card border-0 shadow-sm h-100 ws-card <%= isActive ? 'active-ws' : 'ended-ws' %>">
            <div class="card-body">
              <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                <div>
                  <h6 class="fw-bold mb-0"><%= w.title %></h6>
                  <div class="text-muted small mt-1">
                    <i class="bi bi-calendar me-1"></i>
                    <%= new Date(w.startDate).toLocaleDateString('en-IN') %> – <%= new Date(w.endDate).toLocaleDateString('en-IN') %>
                  </div>
                  <% if (w.venue) { %>
                  <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i><%= w.venue %></div>
                  <% } %>
                </div>
                <span class="badge <%= isActive ? 'bg-success' : 'bg-secondary' %> flex-shrink-0">
                  <%= isActive ? 'Active' : 'Ended' %>
                </span>
              </div>

              <!-- Attendance progress -->
              <% if (e.totalSessions > 0) { %>
              <div class="mb-2">
                <div class="d-flex justify-content-between small mb-1">
                  <span class="text-muted">Attendance</span>
                  <span class="fw-semibold <%= e.attendancePct >= 75 ? 'text-success' : e.attendancePct >= 50 ? 'text-warning' : 'text-danger' %>">
                    <%= e.markedSessions %>/<%= e.totalSessions %> sessions (<%= e.attendancePct %>%)
                  </span>
                </div>
                <div class="progress" style="height:5px;">
                  <div class="progress-bar <%= e.attendancePct >= 75 ? 'bg-success' : e.attendancePct >= 50 ? 'bg-warning' : 'bg-danger' %>"
                       style="width:<%= e.attendancePct %>%"></div>
                </div>
              </div>
              <% } %>

              <!-- Tasks progress -->
              <% if (e.totalTasks > 0) { %>
              <div class="mb-3">
                <div class="d-flex justify-content-between small mb-1">
                  <span class="text-muted">Tasks</span>
                  <span class="fw-semibold <%= e.doneTasksCount === e.totalTasks ? 'text-success' : 'text-muted' %>">
                    <%= e.doneTasksCount %>/<%= e.totalTasks %> submitted
                  </span>
                </div>
                <div class="progress" style="height:5px;">
                  <div class="progress-bar bg-primary"
                       style="width:<%= e.totalTasks > 0 ? Math.round(e.doneTasksCount/e.totalTasks*100) : 0 %>%"></div>
                </div>
              </div>
              <% } %>

              <div class="d-flex align-items-center justify-content-between mt-auto pt-2 border-top">
                <span class="badge <%= e.paymentStatus === 'free' ? 'bg-info bg-opacity-10 text-info' : 'bg-success bg-opacity-10 text-success' %>">
                  <%= e.paymentStatus === 'free' ? 'Free enrollment' : '₹' + e.fee + ' paid' %>
                </span>
                <a href="/student/workshops/<%= w._id %>" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-door-open me-1"></i>Enter Room
                </a>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- ═══════ EDIT PROFILE TAB ═══════ -->
    <div class="tab-pane fade" id="tab-edit">
      <div class="edit-card mx-auto">
        <div class="card border-0 shadow-sm">
          <div class="card-header"><span class="section-title"><i class="bi bi-pencil-square me-2"></i>Edit Profile</span></div>
          <div class="card-body p-4">
            <form action="/student/profile" method="POST">
              <div class="mb-3">
                <label class="form-label">Full Name</label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0"><i class="bi bi-person text-muted"></i></span>
                  <input type="text" name="name" class="form-control border-start-0"
                         value="<%= user.name || '' %>" placeholder="Your full name" maxlength="60">
                </div>
                <div class="form-text">This name appears on your PDF reports and results.</div>
              </div>
              <div class="mb-3">
                <label class="form-label">Email Address</label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                  <input type="email" class="form-control border-start-0" value="<%= user.email %>" disabled>
                </div>
                <div class="form-text">Email cannot be changed.</div>
              </div>
              <div class="mb-3">
                <label class="form-label">Mobile Number</label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0"><i class="bi bi-phone text-muted"></i></span>
                  <input type="text" class="form-control border-start-0" value="<%= user.mobile || '' %>" disabled>
                </div>
                <div class="form-text">Mobile number cannot be changed after registration.</div>
              </div>
              <div class="mb-4">
                <label class="form-label">College</label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0"><i class="bi bi-building text-muted"></i></span>
                  <input type="text" class="form-control border-start-0" value="<%= user.collegeName || 'Not assigned' %>" disabled>
                </div>
                <div class="form-text">College is assigned during registration.</div>
              </div>
              <div class="d-flex gap-2 justify-content-end">
                <a href="/student/dashboard" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary px-4">
                  <i class="bi bi-save me-1"></i>Save Changes
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // If page loaded via flash redirect, switch to edit tab
  <% if (success_msg && success_msg.length > 0) { %>
  document.addEventListener('DOMContentLoaded', () => {
    new bootstrap.Tab(document.querySelector('[data-bs-target="#tab-edit"]')).show();
  });
  <% } %>
</script>
</body>
</html>
