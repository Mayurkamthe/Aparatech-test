<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <%- include('../partials/pwa-head') %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'test' }) %>

<div class="page-header">
  <div class="container">
    <h1><i class="bi bi-info-circle me-2"></i>Test Instructions</h1>
    <p>Please read carefully before you begin.</p>
  </div>
</div>

<main class="container pb-5" style="max-width:700px;">
  <%- include('../partials/flash') %>

  <div class="card mb-4 fade-in">
    <div class="card-header d-flex align-items-center justify-content-between">
      <span class="section-title"><i class="bi bi-journal-text me-2"></i><%= test.title %></span>
      <span class="badge bg-primary"><%= test.domain %></span>
    </div>
    <div class="card-body">
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3 text-center">
          <div class="p-3 rounded-2 bg-primary bg-opacity-10">
            <i class="bi bi-clock text-primary fs-3 d-block mb-1"></i>
            <div class="fw-bold fs-5"><%= test.duration %> min</div>
            <div class="text-muted small">Duration</div>
          </div>
        </div>
        <div class="col-6 col-md-3 text-center">
          <div class="p-3 rounded-2 bg-success bg-opacity-10">
            <i class="bi bi-question-circle text-success fs-3 d-block mb-1"></i>
            <div class="fw-bold fs-5"><%= questionCount %></div>
            <div class="text-muted small">Questions</div>
          </div>
        </div>
        <div class="col-6 col-md-3 text-center">
          <div class="p-3 rounded-2 bg-warning bg-opacity-10">
            <i class="bi bi-award text-warning fs-3 d-block mb-1"></i>
            <div class="fw-bold fs-5"><%= test.totalMarks %></div>
            <div class="text-muted small">Total Marks</div>
          </div>
        </div>
        <div class="col-6 col-md-3 text-center">
          <div class="p-3 rounded-2 bg-info bg-opacity-10">
            <i class="bi bi-check-circle text-info fs-3 d-block mb-1"></i>
            <div class="fw-bold fs-5">
              <%= test.passingMarks > 0 ? test.passingMarks : Math.ceil(test.totalMarks * 0.4) %>
            </div>
            <div class="text-muted small">Passing Marks</div>
          </div>
        </div>
      </div>

      <!-- General Instructions -->
      <h6 class="fw-bold mb-3"><i class="bi bi-list-check me-2 text-primary"></i>General Instructions</h6>
      <ul class="list-group list-group-flush mb-3">
        <li class="list-group-item ps-0 border-0 pb-2">
          <i class="bi bi-shuffle text-primary me-2"></i>
          Questions will be <strong>randomized</strong> and options will be <strong>shuffled</strong> for each student.
        </li>
        <li class="list-group-item ps-0 border-0 pb-2">
          <i class="bi bi-clock-history text-warning me-2"></i>
          The test will <strong>auto-submit</strong> when the timer reaches zero.
        </li>
        <li class="list-group-item ps-0 border-0 pb-2">
          <i class="bi bi-arrow-counterclockwise text-danger me-2"></i>
          <strong>Do not refresh or navigate away</strong> — the test will auto-submit if you do.
        </li>
        <li class="list-group-item ps-0 border-0 pb-2">
          <i class="bi bi-display text-danger me-2"></i>
          You will be asked to enter <strong>fullscreen mode</strong>. Exiting fullscreen will trigger a warning.
        </li>
        <li class="list-group-item ps-0 border-0 pb-2">
          <i class="bi bi-eye-slash text-danger me-2"></i>
          <strong>Tab switching</strong> is monitored. After <strong>3 warnings</strong>, the test auto-submits.
        </li>
        <li class="list-group-item ps-0 border-0 pb-2">
          <i class="bi bi-hand-index text-muted me-2"></i>
          Right-click and copy/paste are <strong>disabled</strong> during the test.
        </li>
        <li class="list-group-item ps-0 border-0 pb-2">
          <i class="bi bi-check2-all text-success me-2"></i>
          You can attempt each test <strong>only once</strong>.
        </li>
      </ul>

      <% if (test.instructions) { %>
      <div class="alert alert-info border-0">
        <h6 class="fw-bold mb-1"><i class="bi bi-chat-quote me-1"></i>Admin Instructions</h6>
        <p class="mb-0 small"><%= test.instructions %></p>
      </div>
      <% } %>

      <hr>
      <div class="d-flex gap-3 justify-content-between align-items-center">
        <a href="/student/enter-code" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        <div class="form-check mb-0">
          <input class="form-check-input" type="checkbox" id="agreeCheck">
          <label class="form-check-label small" for="agreeCheck">
            I have read all instructions and I'm ready to begin.
          </label>
        </div>
        <a href="/student/test/<%= test._id %>/start" class="btn btn-primary px-4" id="startBtn" disabled>
          <i class="bi bi-play-fill me-1"></i>Start Test
        </a>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.getElementById('agreeCheck').addEventListener('change', function () {
    document.getElementById('startBtn').disabled = !this.checked;
  });
</script>
</body>
</html>
