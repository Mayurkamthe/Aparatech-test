<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <%- include('../partials/pwa-head') %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
  <style>
    .result-hero {
      background: linear-gradient(135deg, var(--primary-dark), var(--primary-light));
      color: #fff;
      padding: 3rem 0 2.5rem;
    }
    .ring-wrapper {
      width: 160px; height: 160px;
      position: relative; margin: 0 auto;
    }
    .ring-svg { transform: rotate(-90deg); }
    .ring-text {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
    }
    .score-pct   { font-size: 2.4rem; font-weight: 800; }
    .score-label { font-size: 0.8rem; opacity: 0.7; }
  </style>
</head>
<body>
<%- include('../partials/header', { activePage: '' }) %>

<!-- Result Hero -->
<div class="result-hero">
  <div class="container text-center">

    <!-- Animated Score Ring -->
    <div class="ring-wrapper mb-3">
      <svg class="ring-svg" width="160" height="160" viewBox="0 0 160 160">
        <circle cx="80" cy="80" r="70" fill="none"
                stroke="rgba(255,255,255,0.15)" stroke-width="14"/>
        <circle cx="80" cy="80" r="70" fill="none"
                stroke="<%= result.isPassed ? '#81c784' : '#e57373' %>"
                stroke-width="14"
                stroke-linecap="round"
                stroke-dasharray="<%= Math.round(2 * Math.PI * 70) %>"
                stroke-dashoffset="<%= Math.round(2 * Math.PI * 70 * (1 - result.percentage / 100)) %>"
                id="scoreRing"
                style="transition: stroke-dashoffset 1.5s ease;"/>
      </svg>
      <div class="ring-text text-white">
        <div class="score-pct"><%= result.percentage.toFixed(1) %>%</div>
        <div class="score-label"><%= result.score %>/<%= result.totalMarks %></div>
      </div>
    </div>

    <h2 class="fw-bold mb-1">
      <% if (result.isPassed) { %>
         Congratulations! You Passed
      <% } else { %>
         Better Luck Next Time
      <% } %>
    </h2>
    <p class="opacity-75 mb-3"><%= result.testTitle %> — <%= result.testDomain %></p>

    <div class="d-flex justify-content-center gap-2 flex-wrap">
      <a href="/student/results/<%= result._id %>/pdf" class="btn btn-light fw-semibold">
        <i class="bi bi-file-pdf me-1 text-danger"></i>Download PDF Report
      </a>
      <button class="btn btn-light fw-semibold" onclick="openShareModal()">
        <i class="bi bi-share me-1 text-primary"></i>Share Result
      </button>
      <a href="/student/dashboard" class="btn btn-outline-light">
        <i class="bi bi-house me-1"></i>Dashboard
      </a>
    </div>

  </div>
</div>

<main class="container pb-5 mt-4">

  <!-- Summary Stats Row -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="card text-center p-3">
        <i class="bi bi-check-circle-fill text-success fs-2 mb-1"></i>
        <div class="fw-bold fs-3 text-success"><%= result.correctCount %></div>
        <div class="text-muted small">Correct</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center p-3">
        <i class="bi bi-x-circle-fill text-danger fs-2 mb-1"></i>
        <div class="fw-bold fs-3 text-danger"><%= result.incorrectCount %></div>
        <div class="text-muted small">Incorrect</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center p-3">
        <i class="bi bi-dash-circle text-warning fs-2 mb-1"></i>
        <div class="fw-bold fs-3 text-warning"><%= result.unattempted %></div>
        <div class="text-muted small">Skipped</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center p-3">
        <i class="bi bi-clock text-primary fs-2 mb-1"></i>
        <div class="fw-bold fs-3 text-primary">
          <%= Math.floor(result.timeTaken/60) %>:<%= String(result.timeTaken%60).padStart(2,'0') %>
        </div>
        <div class="text-muted small">Time Taken</div>
      </div>
    </div>
  </div>

  <!-- Result saved notice -->
  <div class="alert alert-info border-0 d-flex align-items-center gap-2 mb-4">
    <i class="bi bi-check-circle-fill fs-4 text-primary"></i>
    <div>
      <strong>Result Saved</strong> Your result has been recorded for <strong><%= result.studentEmail %></strong>.
    </div>
  </div>

  <!-- Detailed Answers -->
  <div class="card">
    <div class="card-header">
      <span class="section-title"><i class="bi bi-list-check me-2"></i>Detailed Answer Review</span>
    </div>
    <div class="card-body p-3 d-flex flex-column gap-3">
      <% result.answers.forEach((ans, idx) => { %>
      <div class="border rounded-2 p-3
           border-<%= ans.isCorrect ? 'success' : ans.selectedOption === -1 ? 'warning' : 'danger' %>
           border-opacity-25">

        <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
          <span class="question-number">Q<%= idx + 1 %></span>
          <% if (ans.isCorrect) { %>
            <span class="badge bg-success"><i class="bi bi-check me-1"></i>Correct · +<%= ans.marksAwarded %> mark</span>
          <% } else if (ans.selectedOption === -1) { %>
            <span class="badge bg-warning text-dark"><i class="bi bi-dash me-1"></i>Not Attempted</span>
          <% } else { %>
            <span class="badge bg-danger"><i class="bi bi-x me-1"></i>Incorrect · 0 marks</span>
          <% } %>
        </div>

        <p class="question-text mb-3"><%= ans.questionText %></p>

        <div class="d-flex flex-column gap-2">
          <% if (ans.options && ans.options.length) { %>
            <% ans.options.forEach((opt, oIdx) => {
              const isSelected = oIdx === ans.selectedOption;
              const isCorrect  = oIdx === ans.correctOption;
            %>
            <div class="option-label
                 <%= isCorrect ? 'correct' : isSelected && !isCorrect ? 'incorrect' : '' %>"
                 style="cursor:default;">
              <div class="option-letter"><%= ['A','B','C','D'][oIdx] %></div>
              <span><%= opt %></span>
              <% if (isCorrect) { %>
                <i class="bi bi-check-circle-fill text-success ms-auto"></i>
              <% } %>
              <% if (isSelected && !isCorrect) { %>
                <i class="bi bi-x-circle-fill text-danger ms-auto"></i>
              <% } %>
            </div>
            <% }) %>
          <% } %>
        </div>

        <% if (ans.explanation) { %>
        <div class="mt-2 p-2 rounded-2 bg-light small">
          <i class="bi bi-lightbulb-fill text-warning me-1"></i>
          <strong>Explanation:</strong> <%= ans.explanation %>
        </div>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>

</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Animate score ring on page load
  window.addEventListener('load', () => {
    const ring = document.getElementById('scoreRing');
    if (ring) {
      const total = 2 * Math.PI * 70;
      const pct   = <%= result.percentage %>;
      const offset = total * (1 - pct / 100);
      ring.style.strokeDashoffset = total; // start from 0
      setTimeout(() => {
        ring.style.strokeDashoffset = offset;
      }, 200);
    }
  });
</script>

<!-- Share Result Modal -->
<div class="modal fade" id="shareModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-share me-2"></i>Share Your Result</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center pt-2">
        <p class="text-muted small mb-3">Your result card is ready to share on LinkedIn, WhatsApp, or anywhere.</p>
        <canvas id="shareCanvas" style="max-width:100%;border-radius:12px;box-shadow:0 4px 20px rgba(0,0,0,0.15);"></canvas>
        <div class="d-flex gap-2 justify-content-center mt-3 flex-wrap">
          <button class="btn btn-primary fw-semibold" onclick="downloadCard()">
            <i class="bi bi-download me-1"></i>Download Image
          </button>
          <button class="btn btn-success fw-semibold" onclick="shareWhatsApp()">
            <i class="bi bi-whatsapp me-1"></i>WhatsApp
          </button>
          <button class="btn btn-outline-primary fw-semibold" onclick="shareLinkedIn()">
            <i class="bi bi-linkedin me-1"></i>LinkedIn
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const RESULT = {
  studentName:  '<%= (result.studentName || "Student").replace(/'/g, "") %>',
  collegeName:  '<%= (result.collegeName || "").replace(/'/g, "") %>',
  testTitle:    '<%= result.testTitle.replace(/'/g, "") %>',
  testDomain:   '<%= result.testDomain %>',
  score:        '<%= result.score %>',
  totalMarks:   '<%= result.totalMarks %>',
  percentage:   '<%= result.percentage.toFixed(1) %>',
  isPassed:     <%= result.isPassed %>,
  companyName:  '<%= companyName %>'
};

function openShareModal() {
  new bootstrap.Modal(document.getElementById('shareModal')).show();
  setTimeout(drawCard, 200);
}

function drawCard() {
  const canvas = document.getElementById('shareCanvas');
  const W = 1080, H = 566;
  canvas.width = W;
  canvas.height = H;
  const ctx = canvas.getContext('2d');

  //  Background 
  // Deep navy gradient
  const bg = ctx.createLinearGradient(0, 0, W, H);
  bg.addColorStop(0,   '#0d1b3e');
  bg.addColorStop(0.6, '#0d47a1');
  bg.addColorStop(1,   '#0a2472');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Decorative circles (top-right)
  ctx.save();
  ctx.globalAlpha = 0.07;
  ctx.fillStyle = '#ffffff';
  ctx.beginPath(); ctx.arc(W - 80, -60, 220, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(W + 40, 100, 180, 0, Math.PI * 2); ctx.fill();
  ctx.restore();

  // Decorative circles (bottom-left)
  ctx.save();
  ctx.globalAlpha = 0.05;
  ctx.fillStyle = '#ffffff';
  ctx.beginPath(); ctx.arc(-40, H + 40, 200, 0, Math.PI * 2); ctx.fill();
  ctx.restore();

  //  Left accent bar 
  const accent = ctx.createLinearGradient(0, 0, 0, H);
  accent.addColorStop(0, '#42a5f5');
  accent.addColorStop(1, '#1565c0');
  ctx.fillStyle = accent;
  ctx.fillRect(0, 0, 6, H);

  //  Company name (top-left) 
  ctx.fillStyle = '#90caf9';
  ctx.font = 'bold 28px Arial, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText(RESULT.companyName, 52, 58);

  // Thin separator line under company
  ctx.strokeStyle = 'rgba(255,255,255,0.12)';
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(52, 72); ctx.lineTo(W - 52, 72); ctx.stroke();

  //  "Assessment Result" label 
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.font = '500 20px Arial, sans-serif';
  ctx.fillText('Assessment Result', 52, 108);

  //  Student name 
  ctx.fillStyle = '#ffffff';
  ctx.font = 'bold 52px Arial, sans-serif';
  // Truncate if too long
  let name = RESULT.studentName;
  while (ctx.measureText(name).width > 620 && name.length > 5) name = name.slice(0, -1);
  if (name !== RESULT.studentName) name += '…';
  ctx.fillText(name, 52, 176);

  //  College name 
  if (RESULT.collegeName) {
    ctx.fillStyle = '#90caf9';
    ctx.font = '400 22px Arial, sans-serif';
    let college = RESULT.collegeName;
    while (ctx.measureText(college).width > 620 && college.length > 5) college = college.slice(0, -1);
    if (college !== RESULT.collegeName) college += '…';
    ctx.fillText(college, 52, 214);
  }

  //  Test title 
  ctx.fillStyle = 'rgba(255,255,255,0.75)';
  ctx.font = '400 22px Arial, sans-serif';
  let testTitle = RESULT.testTitle;
  while (ctx.measureText(testTitle).width > 620 && testTitle.length > 5) testTitle = testTitle.slice(0, -1);
  if (testTitle !== RESULT.testTitle) testTitle += '…';
  ctx.fillText(testTitle, 52, 254);

  // Domain pill
  const domainX = 52, domainY = 276;
  const domainW = ctx.measureText(RESULT.testDomain).width + 28;
  ctx.fillStyle = 'rgba(255,255,255,0.1)';
  roundRect(ctx, domainX, domainY, domainW, 30, 15);
  ctx.fill();
  ctx.fillStyle = '#90caf9';
  ctx.font = '500 16px Arial, sans-serif';
  ctx.fillText(RESULT.testDomain, domainX + 14, domainY + 21);

  //  Vertical divider 
  ctx.strokeStyle = 'rgba(255,255,255,0.15)';
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(730, 90); ctx.lineTo(730, H - 90); ctx.stroke();

  //  Score block (right side) 
  const cx = 895;

  // Score fraction
  ctx.fillStyle = '#ffffff';
  ctx.font = 'bold 80px Arial, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText(RESULT.score, cx, 230);

  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.font = '400 28px Arial, sans-serif';
  ctx.fillText('out of ' + RESULT.totalMarks, cx, 268);

  // Percentage
  ctx.fillStyle = '#42a5f5';
  ctx.font = 'bold 48px Arial, sans-serif';
  ctx.fillText(RESULT.percentage + '%', cx, 340);

  // PASS / FAIL badge
  const badgeY = 365;
  const badgeW = 180, badgeH = 52;
  const badgeX = cx - badgeW / 2;
  const isPassed = RESULT.isPassed;
  ctx.fillStyle = isPassed ? 'rgba(46,125,50,0.85)' : 'rgba(183,28,28,0.85)';
  roundRect(ctx, badgeX, badgeY, badgeW, badgeH, 26);
  ctx.fill();
  ctx.fillStyle = '#ffffff';
  ctx.font = 'bold 26px Arial, sans-serif';
  ctx.fillText(isPassed ? 'PASSED' : 'FAILED', cx, badgeY + 35);

  //  Bottom footer bar 
  ctx.fillStyle = 'rgba(255,255,255,0.06)';
  ctx.fillRect(0, H - 58, W, 58);

  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.font = '400 16px Arial, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('Verified by ' + RESULT.companyName + ' Test Portal', 52, H - 22);

  ctx.textAlign = 'right';
  const today = new Date().toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' });
  ctx.fillText(today, W - 52, H - 22);
}

function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function downloadCard() {
  const canvas = document.getElementById('shareCanvas');
  const link = document.createElement('a');
  link.download = 'result-' + RESULT.studentName.replace(/\s+/g, '-') + '.png';
  link.href = canvas.toDataURL('image/png');
  link.click();
}

function shareWhatsApp() {
  const text = encodeURIComponent(
    `I just completed "${RESULT.testTitle}" on ${RESULT.companyName} Test Portal!\n` +
    `Score: ${RESULT.score}/${RESULT.totalMarks} (${RESULT.percentage}%) — ${RESULT.isPassed ? 'PASSED' : 'FAILED'}\n` +
    `Download my result card and check yours at the portal.`
  );
  window.open('https://wa.me/?text=' + text, '_blank');
}

function shareLinkedIn() {
  const text = encodeURIComponent(
    `Scored ${RESULT.percentage}% on "${RESULT.testTitle}" (${RESULT.testDomain}) — ${RESULT.isPassed ? 'PASSED' : 'FAILED'} via ${RESULT.companyName} Test Portal.`
  );
  window.open('https://www.linkedin.com/sharing/share-offsite/?summary=' + text, '_blank');
}
</script>

</body>
</html>
