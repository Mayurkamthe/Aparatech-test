<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <%- include('../partials/pwa-head') %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
  <style>
    .result-hero {
      background: linear-gradient(135deg, var(--primary-dark), var(--primary-light));
      color: #fff;
      padding: 3rem 0 2.5rem;
    }
    .ring-wrapper {
      width: 160px; height: 160px;
      position: relative; margin: 0 auto;
    }
    .ring-svg { transform: rotate(-90deg); }
    .ring-text {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
    }
    .score-pct   { font-size: 2.4rem; font-weight: 800; }
    .score-label { font-size: 0.8rem; opacity: 0.7; }
  </style>
</head>
<body>
<%- include('../partials/header', { activePage: '' }) %>

<!-- Result Hero -->
<div class="result-hero">
  <div class="container text-center">

    <!-- Animated Score Ring -->
    <div class="ring-wrapper mb-3">
      <svg class="ring-svg" width="160" height="160" viewBox="0 0 160 160">
        <circle cx="80" cy="80" r="70" fill="none"
                stroke="rgba(255,255,255,0.15)" stroke-width="14"/>
        <circle cx="80" cy="80" r="70" fill="none"
                stroke="<%= result.isPassed ? '#81c784' : '#e57373' %>"
                stroke-width="14"
                stroke-linecap="round"
                stroke-dasharray="<%= Math.round(2 * Math.PI * 70) %>"
                stroke-dashoffset="<%= Math.round(2 * Math.PI * 70 * (1 - result.percentage / 100)) %>"
                id="scoreRing"
                style="transition: stroke-dashoffset 1.5s ease;"/>
      </svg>
      <div class="ring-text text-white">
        <div class="score-pct"><%= result.percentage.toFixed(1) %>%</div>
        <div class="score-label"><%= result.score %>/<%= result.totalMarks %></div>
      </div>
    </div>

    <h2 class="fw-bold mb-1">
      <% if (result.isPassed) { %>
        🎉 Congratulations! You Passed!
      <% } else { %>
        😔 Better Luck Next Time
      <% } %>
    </h2>
    <p class="opacity-75 mb-3"><%= result.testTitle %> — <%= result.testDomain %></p>

    <div class="d-flex justify-content-center gap-2 flex-wrap">
      <a href="/student/results/<%= result._id %>/pdf" class="btn btn-light fw-semibold">
        <i class="bi bi-file-pdf me-1 text-danger"></i>Download PDF Report
      </a>
      <a href="/student/dashboard" class="btn btn-outline-light">
        <i class="bi bi-house me-1"></i>Dashboard
      </a>
    </div>

  </div>
</div>

<main class="container pb-5 mt-4">

  <!-- Summary Stats Row -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="card text-center p-3">
        <i class="bi bi-check-circle-fill text-success fs-2 mb-1"></i>
        <div class="fw-bold fs-3 text-success"><%= result.correctCount %></div>
        <div class="text-muted small">Correct</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center p-3">
        <i class="bi bi-x-circle-fill text-danger fs-2 mb-1"></i>
        <div class="fw-bold fs-3 text-danger"><%= result.incorrectCount %></div>
        <div class="text-muted small">Incorrect</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center p-3">
        <i class="bi bi-dash-circle text-warning fs-2 mb-1"></i>
        <div class="fw-bold fs-3 text-warning"><%= result.unattempted %></div>
        <div class="text-muted small">Skipped</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center p-3">
        <i class="bi bi-clock text-primary fs-2 mb-1"></i>
        <div class="fw-bold fs-3 text-primary">
          <%= Math.floor(result.timeTaken/60) %>:<%= String(result.timeTaken%60).padStart(2,'0') %>
        </div>
        <div class="text-muted small">Time Taken</div>
      </div>
    </div>
  </div>

  <!-- Result saved notice -->
  <div class="alert alert-info border-0 d-flex align-items-center gap-2 mb-4">
    <i class="bi bi-check-circle-fill fs-4 text-primary"></i>
    <div>
      <strong>Result saved!</strong>
      Your result has been recorded for <strong><%= result.studentEmail %></strong>.
    </div>
  </div>

  <!-- Detailed Answers -->
  <div class="card">
    <div class="card-header">
      <span class="section-title"><i class="bi bi-list-check me-2"></i>Detailed Answer Review</span>
    </div>
    <div class="card-body p-3 d-flex flex-column gap-3">
      <% result.answers.forEach((ans, idx) => { %>
      <div class="border rounded-2 p-3
           border-<%= ans.isCorrect ? 'success' : ans.selectedOption === -1 ? 'warning' : 'danger' %>
           border-opacity-25">

        <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
          <span class="question-number">Q<%= idx + 1 %></span>
          <% if (ans.isCorrect) { %>
            <span class="badge bg-success"><i class="bi bi-check me-1"></i>Correct · +<%= ans.marksAwarded %> mark</span>
          <% } else if (ans.selectedOption === -1) { %>
            <span class="badge bg-warning text-dark"><i class="bi bi-dash me-1"></i>Not Attempted</span>
          <% } else { %>
            <span class="badge bg-danger"><i class="bi bi-x me-1"></i>Incorrect · 0 marks</span>
          <% } %>
        </div>

        <p class="question-text mb-3"><%= ans.questionText %></p>

        <div class="d-flex flex-column gap-2">
          <% if (ans.options && ans.options.length) { %>
            <% ans.options.forEach((opt, oIdx) => {
              const isSelected = oIdx === ans.selectedOption;
              const isCorrect  = oIdx === ans.correctOption;
            %>
            <div class="option-label
                 <%= isCorrect ? 'correct' : isSelected && !isCorrect ? 'incorrect' : '' %>"
                 style="cursor:default;">
              <div class="option-letter"><%= ['A','B','C','D'][oIdx] %></div>
              <span><%= opt %></span>
              <% if (isCorrect) { %>
                <i class="bi bi-check-circle-fill text-success ms-auto"></i>
              <% } %>
              <% if (isSelected && !isCorrect) { %>
                <i class="bi bi-x-circle-fill text-danger ms-auto"></i>
              <% } %>
            </div>
            <% }) %>
          <% } %>
        </div>

        <% if (ans.explanation) { %>
        <div class="mt-2 p-2 rounded-2 bg-light small">
          <i class="bi bi-lightbulb-fill text-warning me-1"></i>
          <strong>Explanation:</strong> <%= ans.explanation %>
        </div>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>

</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Animate score ring on page load
  window.addEventListener('load', () => {
    const ring = document.getElementById('scoreRing');
    if (ring) {
      const total = 2 * Math.PI * 70;
      const pct   = <%= result.percentage %>;
      const offset = total * (1 - pct / 100);
      ring.style.strokeDashoffset = total; // start from 0
      setTimeout(() => {
        ring.style.strokeDashoffset = offset;
      }, 200);
    }
  });
</script>
</body>
</html>
