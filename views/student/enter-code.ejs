<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'test' }) %>

<div class="page-header">
  <div class="container">
    <h1><i class="bi bi-key me-2"></i>Enter Test Code</h1>
    <p>Enter the 6-character code provided by your administrator.</p>
  </div>
</div>

<main class="container pb-5 d-flex align-items-center justify-content-center" style="min-height:60vh;">
  <div style="width:100%;max-width:480px;">
    <%- include('../partials/flash') %>

    <div class="card shadow fade-in">
      <div class="card-body p-4">
        <div class="text-center mb-4">
          <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
               style="width:72px;height:72px;background:var(--accent-light);">
            <i class="bi bi-pencil-square text-primary" style="font-size:1.8rem;"></i>
          </div>
          <h4 class="fw-bold">Start Your Test</h4>
          <p class="text-muted small">Ask your admin for the test code, then enter it below.</p>
        </div>

        <form action="/student/enter-code" method="POST" id="codeForm">
          <div class="mb-3">
            <label class="form-label fw-semibold">Test Code</label>
            <input type="text" name="code" class="form-control text-center fw-bold text-uppercase"
                   style="font-size:1.5rem;letter-spacing:8px;font-family:var(--font-mono);height:60px;"
                   placeholder="XXXXXX" maxlength="6" minlength="6"
                   required autocomplete="off" id="codeInput">
            <div class="form-text text-center">6-character alphanumeric code (e.g. FX93KQ)</div>
          </div>

          <button type="submit" class="btn btn-primary w-100 py-2" id="enterBtn">
            <i class="bi bi-arrow-right-circle me-1"></i>Find Test
          </button>
        </form>

        <div class="alert alert-info border-0 mt-3 small">
          <i class="bi bi-info-circle me-1"></i>
          <strong>Note:</strong> You can only attempt each test once.
          Make sure you're ready before starting!
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const input = document.getElementById('codeInput');
  // Auto-uppercase and only allow valid chars
  input.addEventListener('input', () => {
    input.value = input.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
  });
  document.getElementById('codeForm').addEventListener('submit', () => {
    const btn = document.getElementById('enterBtn');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Searching...';
    btn.disabled = true;
  });
</script>
</body>
</html>
