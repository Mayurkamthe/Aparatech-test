<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <%- include('../partials/pwa-head') %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/header', { activePage: 'dashboard' }) %>

<div class="page-header">
  <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h1><i class="bi bi-house me-2"></i>My Dashboard</h1>
      <p>Welcome, <strong><%= user.name || user.email.split('@')[0] %></strong>! Ready to take a test?</p>
    </div>
    <a href="/student/enter-code" class="btn btn-light fw-semibold">
      <i class="bi bi-pencil-square me-1"></i>Take a Test
    </a>
  </div>
</div>

<main class="container pb-5">
  <%- include('../partials/flash') %>

  <!-- New Workshop Alert -->
  <% if (typeof newWorkshops !== 'undefined' && newWorkshops.length > 0) { %>
  <div class="alert border-0 shadow-sm mb-4 fade-in" style="background:linear-gradient(135deg,#fff3e0,#ffe0b2);border-left:4px solid #ff9800 !important;">
    <div class="d-flex align-items-center gap-3 flex-wrap">
      <div><i class="bi bi-mortarboard-fill fs-3 text-warning"></i></div>
      <div class="flex-grow-1">
        <div class="fw-bold">New Workshop<%= newWorkshops.length > 1 ? 's' : '' %> Available</div>
        <% newWorkshops.forEach(w => { %>
          <div class="small text-muted"><i class="bi bi-mortarboard me-1"></i><strong><%= w.title %></strong> · <%= w.isFree ? 'FREE' : '₹' + w.fee %> · <%= new Date(w.startDate).toLocaleDateString('en-IN') %></div>
        <% }) %>
      </div>
      <a href="/student/workshops" class="btn btn-warning btn-sm fw-semibold">
        <i class="bi bi-arrow-right me-1"></i>View & Enroll
      </a>
    </div>
  </div>
  <% } %>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="stat-card" style="background:linear-gradient(135deg,#0d47a1,#1565c0);">
        <div class="stat-icon"><i class="bi bi-journal-check"></i></div>
        <div>
          <div class="stat-value"><%= results.length %></div>
          <div class="stat-label">Tests Taken</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card" style="background:linear-gradient(135deg,#2e7d32,#43a047);">
        <div class="stat-icon"><i class="bi bi-trophy"></i></div>
        <div>
          <div class="stat-value"><%= results.filter(r => r.isPassed).length %></div>
          <div class="stat-label">Passed</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card" style="background:linear-gradient(135deg,#c62828,#e53935);">
        <div class="stat-icon"><i class="bi bi-x-circle"></i></div>
        <div>
          <div class="stat-value"><%= results.filter(r => !r.isPassed).length %></div>
          <div class="stat-label">Failed</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card" style="background:linear-gradient(135deg,#6a1b9a,#8e24aa);">
        <div class="stat-icon"><i class="bi bi-percent"></i></div>
        <div>
          <div class="stat-value">
            <% if (results.length > 0) { %>
              <%= (results.reduce((a,r) => a + r.percentage, 0) / results.length).toFixed(0) %>%
            <% } else { %>
              —
            <% } %>
          </div>
          <div class="stat-label">Avg Score</div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA if no tests taken -->
  <% if (results.length === 0) { %>
  <div class="card mb-4" style="border:2px dashed var(--gray-300);">
    <div class="card-body empty-state">
      <i class="bi bi-pencil-square"></i>
      <h5>No tests attempted yet</h5>
      <p class="text-muted">Enter a test code given by your admin to get started.</p>
      <a href="/student/enter-code" class="btn btn-primary">
        <i class="bi bi-key me-1"></i>Enter Test Code
      </a>
    </div>
  </div>
  <% } %>

  <!-- My Workshops -->
  <% if (typeof enrolledWorkshops !== 'undefined' && enrolledWorkshops.length > 0) { %>
  <div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between">
      <span class="section-title"><i class="bi bi-mortarboard me-2"></i>My Workshops</span>
      <a href="/student/workshops" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-grid me-1"></i>View All
      </a>
    </div>
    <div class="card-body p-0">
      <div class="list-group list-group-flush">
        <% enrolledWorkshops.forEach(ew => { %>
        <% const w = ew.workshop; %>
        <% const isActive = w.isActive && new Date(w.endDate) >= new Date(); %>
        <a href="/student/workshops/<%= w._id %>"
           class="list-group-item list-group-item-action px-3 py-3"
           style="<%= ew.hasOpenSession ? 'border-left:4px solid #198754;' : isActive ? 'border-left:4px solid #0d6efd;' : 'border-left:4px solid #adb5bd;' %>">
          <div class="d-flex align-items-start gap-3">

            <!-- Left: icon / live badge -->
            <div class="flex-shrink-0 mt-1">
              <% if (ew.hasOpenSession) { %>
                <span class="badge bg-success px-2 py-1" style="font-size:0.7rem;">
                  <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;"></i>LIVE
                </span>
              <% } else if (isActive) { %>
                <span class="badge bg-primary bg-opacity-10 text-primary px-2 py-1" style="font-size:0.7rem;">Active</span>
              <% } else { %>
                <span class="badge bg-secondary bg-opacity-10 text-secondary px-2 py-1" style="font-size:0.7rem;">Ended</span>
              <% } %>
            </div>

            <!-- Middle: workshop info -->
            <div class="flex-grow-1 min-w-0">
              <div class="fw-semibold text-truncate"><%= w.title %></div>
              <div class="text-muted small mt-1">
                <i class="bi bi-calendar3 me-1"></i>
                <%= new Date(w.startDate).toLocaleDateString('en-IN') %> – <%= new Date(w.endDate).toLocaleDateString('en-IN') %>
                <% if (w.venue) { %> · <i class="bi bi-geo-alt me-1"></i><%= w.venue %><% } %>
              </div>

              <!-- Attendance progress bar -->
              <% if (ew.totalSessions > 0) { %>
              <div class="mt-2">
                <div class="d-flex justify-content-between" style="font-size:0.75rem;">
                  <span class="text-muted">Attendance</span>
                  <span class="fw-semibold <%= ew.attendancePct >= 75 ? 'text-success' : ew.attendancePct >= 50 ? 'text-warning' : 'text-danger' %>">
                    <%= ew.markedSessions %>/<%= ew.totalSessions %> sessions (<%= ew.attendancePct %>%)
                  </span>
                </div>
                <div class="progress mt-1" style="height:4px;">
                  <div class="progress-bar <%= ew.attendancePct >= 75 ? 'bg-success' : ew.attendancePct >= 50 ? 'bg-warning' : 'bg-danger' %>"
                       style="width:<%= ew.attendancePct %>%"></div>
                </div>
              </div>
              <% } %>

              <!-- Open session alert -->
              <% if (ew.hasOpenSession) { %>
              <div class="mt-2">
                <span class="badge bg-success bg-opacity-10 text-success" style="font-size:0.75rem;">
                  <i class="bi bi-clipboard-check me-1"></i>
                  Attendance open — tap to mark
                </span>
              </div>
              <% } %>
            </div>

            <!-- Right: chevron -->
            <div class="flex-shrink-0 text-muted align-self-center">
              <i class="bi bi-chevron-right"></i>
            </div>

          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Test History -->
  <% if (results.length > 0) { %>
  <div class="card">
    <div class="card-header">
      <span class="section-title"><i class="bi bi-clock-history me-2"></i>My Test History</span>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>#</th>
              <th>Test</th>
              <th>Score</th>
              <th>Status</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% results.forEach((r, idx) => { %>
            <tr>
              <td class="text-muted"><%= idx + 1 %></td>
              <td>
                <div class="fw-semibold"><%= r.testTitle %></div>
                <span class="badge bg-primary bg-opacity-10 text-primary small"><%= r.testDomain %></span>
              </td>
              <td>
                <div class="fw-bold text-mono"><%= r.score %>/<%= r.totalMarks %></div>
                <div class="progress mt-1" style="height:4px;width:80px;">
                  <div class="progress-bar" style="width:<%= r.percentage %>%"></div>
                </div>
                <small class="text-muted"><%= r.percentage.toFixed(1) %>%</small>
              </td>
              <td>
                <% if (r.isPassed) { %>
                  <span class="badge bg-success"><i class="bi bi-check me-1"></i>Passed</span>
                <% } else { %>
                  <span class="badge bg-danger"><i class="bi bi-x me-1"></i>Failed</span>
                <% } %>
              </td>
              <td class="text-muted small">
                <%= new Date(r.submittedAt).toLocaleDateString('en-IN') %>
              </td>
              <td>
                <a href="/student/results/<%= r._id %>" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-eye me-1"></i>View
                </a>
                <a href="/student/results/<%= r._id %>/pdf" class="btn btn-sm btn-outline-danger ms-1">
                  <i class="bi bi-file-pdf"></i>
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>

</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
