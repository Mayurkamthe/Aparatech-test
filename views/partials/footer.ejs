<footer class="site-footer">
  <div class="container">
    <div class="row align-items-center g-3">
      <div class="col-12 col-md-5">
        <div class="footer-brand"><%= companyFullName || 'OMVSAB IT SOLUTION' %></div>
        <div class="footer-tagline"><%= companyTagline || 'We code your Requirements' %></div>
        <div class="mt-2 d-flex flex-wrap gap-2">
          <span class="footer-badge"><i class="bi bi-shield-check me-1"></i>Secure Portal</span>
          <span class="footer-badge"><i class="bi bi-patch-check me-1"></i>Verified Results</span>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="small mb-1"><i class="bi bi-geo-alt me-1 text-warning"></i><%= companyAddress || 'Karve Nagar, Pune – 411052, Maharashtra' %></div>
        <div class="small mb-1"><i class="bi bi-telephone me-1 text-warning"></i><%= companyPhone || '+91-20-6522-2520' %></div>
        <div class="small mb-1"><i class="bi bi-envelope me-1 text-warning"></i>
          <a href="mailto:<%= companyEmail || 'hr@omvsabitsolution.in' %>"><%= companyEmail || 'hr@omvsabitsolution.in' %></a>
        </div>
        <div class="small"><i class="bi bi-globe me-1 text-warning"></i>
          <a href="https://<%= companyWebsite || 'www.omvsabitsolution.in' %>" target="_blank"><%= companyWebsite || 'www.omvsabitsolution.in' %></a>
        </div>
      </div>
      <div class="col-12 col-md-3 text-md-end">
        <div class="small opacity-60">&copy; <%= new Date().getFullYear() %> <%= companyFullName || 'OMVSAB IT SOLUTION' %></div>
        <div class="small opacity-50 mt-1">All rights reserved.</div>
      </div>
    </div>
