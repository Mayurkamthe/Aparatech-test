# ==========================================
# APARAITECH TEST PORTAL - Environment Config
# ==========================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/aparaitech_test_portal

# JWT Secret (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Session Secret
SESSION_SECRET=your_session_secret_key_change_this_too

# ==========================================
# ADMIN CREDENTIALS (hardcoded admin via env)
# ==========================================
ADMIN_EMAIL=admin@aparaitechsoftware.org
ADMIN_PASSWORD=Admin@APARAI2024

# ==========================================
# NODEMAILER - SMTP Configuration
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@aparaitechsoftware.org
SMTP_PASS=your_email_app_password_here

# OTP expiry time in minutes
OTP_EXPIRY_MINUTES=10

# ==========================================
# COMPANY DETAILS (used in emails & PDFs)
# ==========================================
